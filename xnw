-- ============================================
-- BALL DATA TRACKING (PreLocal) - CORE GAME LOGIC
-- ============================================
RunService.PreLocal:Connect(function()
    if not _G.AutoParryState.ThreadRunning then
        return
    end
    pcall(function()
        local currentTime = tick()
        local deltaTime = currentTime - _G.AutoParryState.LastFrameTime
        _G.AutoParryState.LastFrameTime = currentTime
        
        local Ball = GetCurrentBall()
        local Character = _G.AutoParryState.CachedCharacter
        local HRP = _G.AutoParryState.CachedHRP
        
        if Ball and Character and HRP then
            local ball_velocity = _G.GetBallVelocity(Ball)
            local Speed = VectorMagnitude(ball_velocity)
            local playerPos = HRP.Position
            local ballPos = Ball.Position
            local dx = ballPos.X - playerPos.X
            local dy = ballPos.Y - playerPos.Y
            local dz = ballPos.Z - playerPos.Z
            local Distance = SQRT(dx*dx + dy*dy + dz*dz)
            
            if _G.AutoParryState.BallData.initialDistance == 999 then
                _G.AutoParryState.BallData.initialDistance = Distance
            end
            if Distance < _G.AutoParryState.BallData.lastDistance then
                _G.AutoParryState.BallData.hasApproached = true
            end
            _G.AutoParryState.BallData.lastDistance = Distance
            
            local isTargeted = _G.AutoParryState.BallData.isTargeted
            local lastSpeed = _G.AutoParryState.BallData.lastKnownSpeed
            
            if Config.MidFlightFreezeEnabled and isTargeted then
                if lastSpeed > Config.MidFlightFreezeMinPreviousSpeed and Speed < Config.MidFlightFreezeSpeedThreshold then
                    _G.AutoParryState.BallData.isMidFlightFrozen = true
                    _G.AutoParryState.BallData.wasFastBeforeFreeze = true
                elseif _G.AutoParryState.BallData.isMidFlightFrozen and Speed > Config.MidFlightFreezeSpeedThreshold then
                    _G.AutoParryState.BallData.isMidFlightFrozen = false
                    _G.AutoParryState.Clicked = false
                end
            else
                _G.AutoParryState.BallData.isMidFlightFrozen = false
                _G.AutoParryState.BallData.wasFastBeforeFreeze = false
            end
            
            _G.AutoParryState.BallData.lastKnownSpeed = Speed
            table.insert(_G.AutoParryState.BallData.speedHistory, Speed)
            if #_G.AutoParryState.BallData.speedHistory > 5 then
                table.remove(_G.AutoParryState.BallData.speedHistory, 1)
            end
            
            local acceleration = 0
            if #_G.AutoParryState.BallData.speedHistory >= 2 then
                local oldSpeed = _G.AutoParryState.BallData.speedHistory[1]
                acceleration = Speed - oldSpeed
            end
            
            local isAeroSlash, aeroPhase, yVelocity, timeInPhase = DetectAerodynamicSlash(Ball)
            _G.AutoParryState.BallData.isAerodynamicSlash = isAeroSlash
            _G.AutoParryState.BallData.aeroSlashPhase = aeroPhase
            _G.AutoParryState.BallData.aeroSlashTimeInPhase = timeInPhase
            _G.AutoParryState.BallData.verticalVelocity = yVelocity
            _G.AutoParryState.BallData.isDescending = yVelocity < 0
            
            local isCurving, curveIntensity, lateralVel = DetectCurve(Ball, ball_velocity)
            _G.AutoParryState.BallData.isCurving = isCurving
            _G.AutoParryState.BallData.curveIntensity = curveIntensity
            _G.AutoParryState.BallData.lateralVelocity = lateralVel
            
            _G.AutoParryState.BallData.ball = Ball
            _G.AutoParryState.BallData.speed = Speed
            _G.AutoParryState.BallData.distance = Distance
            _G.AutoParryState.BallData.acceleration = acceleration
            _G.AutoParryState.BallData.valid = (Speed > Config.MinParrySpeed)
            _G.AutoParryState.BallData.speedCategory = GetSpeedCategory(Speed)
            
            local matrixParryTime = CalculateMatrixStyleParryTime(
                Speed, Distance, acceleration,
                isAeroSlash, aeroPhase, timeInPhase,
                isCurving, curveIntensity
            )
            _G.AutoParryState.BallData.adaptiveParryTime = matrixParryTime
            _G.AutoParryState.BallData.deadZoneAdjustedTime = matrixParryTime
            
            if Speed > 0 then
                local adjustedDistance = MAX(0, Distance - Config.ParryBufferDistance)
                local speedMultiplier = 1.0
                if Speed >= 150 then speedMultiplier = 1.15 end
                if Speed >= 200 then speedMultiplier = 1.25 end
                if Speed >= 300 then speedMultiplier = 1.40 end
                if Speed >= 450 then speedMultiplier = 1.60 end
                if Speed >= 600 then speedMultiplier = 1.85 end
                if Speed >= 800 then speedMultiplier = 2.10 end
                if Speed >= 1000 then speedMultiplier = 2.50 end
                _G.AutoParryState.BallData.timeToReach = (adjustedDistance / Speed) * speedMultiplier
            else
                _G.AutoParryState.BallData.timeToReach = 999
            end
            
            if ShouldCheckDirection(Distance) then
                local dirToPlayer = NormalizeVector(playerPos - ballPos)
                local velDir = NormalizeVector(ball_velocity)
                local dot = DotProduct(velDir, dirToPlayer)
                _G.AutoParryState.BallData.movingTowardsPlayer = dot > 0.2
                _G.AutoParryState.BallData.shouldParry = dot > 0.2
            else
                _G.AutoParryState.BallData.movingTowardsPlayer = true
                _G.AutoParryState.BallData.shouldParry = true
            end
        else
            _G.AutoParryState.BallData.valid = false
            _G.AutoParryState.BallData.shouldParry = false
            _G.AutoParryState.BallData.movingTowardsPlayer = false
            _G.AutoParryState.BallData.timeToReach = 999
            _G.AutoParryState.BallData.adaptiveParryTime = Config.BaseParryTime
            _G.AutoParryState.BallData.deadZoneAdjustedTime = Config.BaseParryTime
            _G.AutoParryState.BallData.isAerodynamicSlash = false
            _G.AutoParryState.BallData.aeroSlashPhase = "none"
            _G.AutoParryState.BallData.speedHistory = {}
            _G.AutoParryState.BallData.velocityHistory = {}
            _G.AutoParryState.BallData.acceleration = 0
        end
    end)
end)

