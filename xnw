local function RefreshPressedKeys()
    local ok, keys = pcall(getpressedkeys)
    if ok and keys then
        _pressedKeys = keys
        _pressedSet = {}
        for _, k in ipairs(keys) do
            _pressedSet[k] = true
        end
    else
        _pressedKeys = {}
        _pressedSet = {}
    end
end

