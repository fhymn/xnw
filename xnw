local function DrawDropdownFlagList(ddID, items, flags, mx, my, lDown, prevLMB, pickerIDs, pickerTitles)
    if Menu.OpenDropdownID ~= ddID then return flags end

    local itemH = 20
    local listH = #items * itemH
    local x, y, w = Menu.DDPosX, Menu.DDPosY, Menu.DDPosW

    DrawMenuRect(x, y, w, listH, 30, 30, 30)
    DrawMenuBorder(x, y, w, listH, 70, 70, 70)

    local newFlags = flags
    for i, item in ipairs(items) do
        local iy = y + (i - 1) * itemH
        local hover = mx >= x and mx <= x + w and my >= iy and my <= iy + itemH
        if hover then
            DrawMenuRect(x + 1, iy, w - 2, itemH, 50, 50, 50)
        end

        local bit = bit32.lshift(1, i - 1)
        local active = bit32.band(newFlags, bit) ~= 0
        local clr = active and {220, 220, 220} or {100, 100, 100}

        local checkX = x + 4
        local checkY = iy + 4
        local checkSz = 12
        DrawMenuRect(checkX, checkY, checkSz, checkSz, 40, 40, 40)
        DrawMenuBorder(checkX, checkY, checkSz, checkSz, 70, 70, 70)
        if active then
            DrawLine(checkX + 2, checkY + checkSz / 2, checkX + checkSz / 2 - 1, checkY + checkSz - 3, 220, 220, 220, 255, 1.5)
            DrawLine(checkX + checkSz / 2 - 1, checkY + checkSz - 3, checkX + checkSz - 2, checkY + 2, 220, 220, 220, 255, 1.5)
        end

        DrawTextShadow(item, x + 22, iy + 3, clr[1], clr[2], clr[3], 255, 0, 0, 0, 255)

        if pickerIDs and pickerIDs[i] and pickerIDs[i] > 0 then
            local cpSz = 12
            local cpX = x + w - cpSz - 6
            local cpY = iy + 4
            local pr, pg, pb = GetPickerColorRGB(pickerIDs[i])
            DrawMenuRect(cpX, cpY, cpSz, cpSz, pr, pg, pb)
            DrawMenuBorder(cpX, cpY, cpSz, cpSz, 70, 70, 70)

            if Menu.PickerOpenID == 0 then
                local cpHover = mx >= cpX and mx <= cpX + cpSz and my >= cpY and my <= cpY + cpSz
                if cpHover and lDown and not prevLMB then
                    Menu.PickerOpenID = pickerIDs[i]
                    Menu.PickerJustOpened = true
                    Menu.PickerTitle = (pickerTitles and pickerTitles[i]) or (item .. " Color")
                    Menu.PickerAnchorX = cpX
                    Menu.PickerAnchorY = cpY
                    Menu.PickerDrag = 0
                end
            end
        end

        local cpAreaX = (pickerIDs and pickerIDs[i] and pickerIDs[i] > 0) and (x + w - 24) or (x + w + 1)
        if hover and lDown and not prevLMB and mx < cpAreaX then
            newFlags = bit32.bxor(newFlags, bit)
        end
    end

    if Menu.DDJustOpened then
        Menu.DDJustOpened = false
    elseif Menu.PickerOpenID == 0 then
        local outside = mx < x or mx > x + w or my < y or my > y + listH
        if outside and lDown and not prevLMB then
            Menu.OpenDropdownID = 0
        end
    end

    return newFlags
end

