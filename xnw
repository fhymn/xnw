    pcall(function()
        local isCurrentlyTargeted = _G.AutoParryState.BallData.isTargeted
        if not isCurrentlyTargeted then
            _G.AutoParryState.Clicked = false
            _G.AutoParryState.ActionFlags.ClickInProgress = false
            _G.AutoParryState.ActionFlags.NormalClickActive = false
        end
