local function DetectAerodynamicSlash(ball)
    if not Config.AerodynamicSlashDetection or not ball then
        return false, "none", 0, 0
    end
    
    local isAeroSlash = false
    local phase = "none"
    local yVelocity = 0
    local timeInPhase = 0
    
    pcall(function()
        local velocity = _G.GetBallVelocity(ball)
        yVelocity = velocity.Y
        local speed = VectorMagnitude(velocity)
        local angularVel = ball.AssemblyAngularVelocity or ZERO_VECTOR
        local angularSpeed = VectorMagnitude(angularVel)
        local lastSpeed = _G.AutoParryState.BallData.speed or 0
        local speedIncrease = speed - lastSpeed
        
        if speedIncrease > 300 and speed > 1000 and angularSpeed < 5 then
            isAeroSlash = true
        end
        
        local abilityType = ball:GetAttribute("AbilityType")
        if abilityType == "AerodynamicSlash" or abilityType == "Slash" then
            isAeroSlash = true
        end
        
        local ballName = ball.Name or ""
        if ballName:lower():find("aero") or ballName:lower():find("slash") then
            isAeroSlash = true
        end
        
        if speed > 1500 and angularSpeed < 3 then
            isAeroSlash = true
        end
        
        if isAeroSlash then
            local currentTime = tick()
            local prevActivationTime = _G.AutoParryState.BallData.aeroSlashActivationTime
            if prevActivationTime == 0 or (currentTime - prevActivationTime) > 2.0 then
                _G.AutoParryState.BallData.aeroSlashActivationTime = currentTime
                timeInPhase = 0
                if speed > 1200 and angularSpeed < 5 then
                    phase = "velocity_injection"
                else
                    phase = "wind_up_bait"
                end
            else
                timeInPhase = currentTime - prevActivationTime
                if timeInPhase <= Config.AeroSlash_WindUpBuffer then
                    phase = "wind_up_bait"
                elseif timeInPhase <= (Config.AeroSlash_WindUpBuffer + Config.AeroSlash_LockFrame) then
                    phase = "aerodynamic_lock"
                elseif timeInPhase <= (Config.AeroSlash_WindUpBuffer + Config.AeroSlash_LockFrame + Config.AeroSlash_VelocityInjection) then
                    phase = "velocity_injection"
                elseif timeInPhase <= Config.AeroSlash_TotalLockoutTime then
                    phase = "unfair_window"
                elseif timeInPhase <= (Config.AeroSlash_TotalLockoutTime + Config.AeroSlash_ParryReEnable) then
                    phase = "parry_compressed"
                else
                    phase = "post_slash"
                    if timeInPhase > 0.5 then
                        isAeroSlash = false
                        phase = "none"
                        _G.AutoParryState.BallData.aeroSlashActivationTime = 0
                    end
                end
            end
        end
    end)
    
    return isAeroSlash, phase, yVelocity, timeInPhase
end

local function GetCurrentBall()
    if _G.AutoParryState.CachedBallsFolder then
        local children = _G.AutoParryState.CachedBallsFolder:GetChildren()
        if children and #children > 0 then
            return children[1]
        end
    end
    return nil
end

function GetPlayerPosition()
    if _G.AutoParryState.CachedHRP then
        return _G.AutoParryState.CachedHRP.Position
    end
    return nil
end

local function IsTargeted()
    return _G.AutoParryState.CachedPlayerModel and _G.AutoParryState.CachedPlayerModel:FindFirstChild("Highlight") ~= nil
end

local function NormalizeVector(v)
    local mag = VectorMagnitude(v)
    if mag > 0 then
        return v / mag
    end
    return ZERO_VECTOR
end

local function DotProduct(a, b)
    return a.X * b.X + a.Y * b.Y + a.Z * b.Z
end

local function ShouldCheckDirection(distance)
    if not Config.DirectionCheckEnabled then
        return false
    end
    if Config.IgnoreDirectionAtCloseRange and distance <= Config.CloseRangeDistance then
        return false
    end
    return true
end

