local function GetSpeedCategory(speed)
    if speed < 200 then
        return "slow"
    elseif speed < 300 then
        return "tier1"
    elseif speed < 400 then
        return "tier2"
    elseif speed < 750 then
        return "tier3"
    else
        return "extreme"
    end
end

local function GetDistanceSpeedMultiplier(distance, speed)
    if not Config.UseDistanceSpeedCorrelation then
        return 1.0, 0
    end
    for _, range in ipairs(Config.DistanceSpeedRanges) do
        local minDist = range[1]
        local maxDist = range[2]
        local baseMultiplier = range[3]
        local speedScaling = range[4]
        if distance >= minDist and distance < maxDist then
            local speedAdjustment = speed * speedScaling
            return baseMultiplier, speedAdjustment
        end
    end
    return 1.0, 0
end

local function GetProgressiveDistanceMultiplier(distance)
    if not Config.ProgressiveDistanceEnabled then
        return 1.0
    end
    for _, range in ipairs(Config.ProgressiveDistanceRanges) do
        local maxDist = range[1]
        local multiplier = range[2]
        if distance <= maxDist then
            return multiplier
        end
    end
    return 1.0
end

local function GetRapidFireSettings(distance)
    if not Config.AdaptiveRapidFireEnabled then
        return 1, true
    end
    for _, range in ipairs(Config.RapidFireDistanceRanges) do
        local maxDist = range[1]
        local clicksPerFrame = range[2]
        local useCalculatedTiming = range[3]
        if distance <= maxDist then
            return clicksPerFrame, useCalculatedTiming
        end
    end
    return 1, true
end

local function GetPingBasedAdjustment(ping)
    if not Config.PingAdaptiveEnabled then
        return 0, 1.0
    end
    for _, bracket in ipairs(Config.PingBrackets) do
        local maxPing = bracket[1]
        local baseOffset = bracket[2]
        local multiplier = bracket[3]
        if ping <= maxPing then
            return baseOffset, multiplier
        end
    end
    return 0.070, 1.70
end

local function CalculateMatrixStyleParryTime(speed, distance, acceleration, isAeroSlash, aeroPhase, aeroTimeInPhase, isCurving, curveIntensity)
    local parryTime = Config.BaseParryTime
    
    -- AERODYNAMIC SLASH handling
    if isAeroSlash then
        if aeroPhase == "wind_up_bait" or aeroPhase == "aerodynamic_lock" or aeroPhase == "velocity_injection" or aeroPhase == "unfair_window" then
            return 999
        elseif aeroPhase == "parry_compressed" then
            parryTime = Config.AeroSlash_OptimalParryDelay
        elseif aeroPhase == "post_slash" then
            parryTime = parryTime * Config.AeroSlashParryDelayMultiplier
        else
            return 999
        end
    end
    
    -- Distance-Speed Correlation
    local distanceMultiplier, speedAdjustment = GetDistanceSpeedMultiplier(distance, speed)
    
    -- Progressive Distance Multiplier
    local progressiveDistMultiplier = GetProgressiveDistanceMultiplier(distance)
    
    -- Dead zone calculation
    if not isAeroSlash or (isAeroSlash and aeroPhase ~= "lock" and aeroPhase ~= "wind_up" and aeroPhase ~= "input_buffer" and aeroPhase ~= "velocity_injection" and aeroPhase ~= "recovery") then
        if speed < Config.SlowBallThreshold then
            parryTime = Config.BaseParryTime * 0.55
        else
            local speedExcess = speed - Config.SlowBallThreshold
            local predictionWindow = (speedExcess / 55) * (Config.DeadZone / 2.3)
            parryTime = Config.BaseParryTime + predictionWindow
            
            if speed >= 200 then
                local tier05Excess = speed - 200
                local tier05Bonus = (tier05Excess / 160) * Config.DeadZone * 0.85
                if distance < 40 then tier05Bonus = tier05Bonus * 0.95 end
                parryTime = parryTime + tier05Bonus
            end
            if speed >= 250 then
                local tier1Excess = speed - 250
                local tier1Bonus = (tier1Excess / 150) * Config.DeadZone * 1.00
                if distance < 40 then tier1Bonus = tier1Bonus * 0.95 end
                parryTime = parryTime + tier1Bonus
            end
            if speed >= 500 then
                local tier2Excess = speed - 500
                local tier2Bonus = (tier2Excess / 180) * Config.DeadZone * 1.00
                if distance < 40 then tier2Bonus = tier2Bonus * 0.92 end
                parryTime = parryTime + tier2Bonus
            end
            if speed >= 700 then
                local tier3Excess = speed - 700
                local tier3Bonus = (tier3Excess / 150) * Config.DeadZone * 1.50
                if distance < 40 then tier3Bonus = tier3Bonus * 0.95 end
                parryTime = parryTime + tier3Bonus
            end
            if speed >= 900 then
                local extremeExcess = speed - 900
                local extremeBonus = (extremeExcess / 130) * Config.DeadZone * 2.00
                if distance < 40 then extremeBonus = extremeBonus * 0.95 end
                parryTime = parryTime + extremeBonus
            end
            if speed >= 1200 then
                local ultraExcess = speed - 1200
                local ultraBonus = (ultraExcess / 100) * Config.DeadZone * 2.50
                parryTime = parryTime + ultraBonus
            end
            if speed >= 1500 then
                local maxExcess = speed - 1500
                local maxBonus = (maxExcess / 80) * Config.DeadZone * 3.00
                parryTime = parryTime + maxBonus
            end
        end
    end
    
    -- Acceleration Compensation
    if Config.UseAccelerationCompensation and acceleration ~= 0 then
        if acceleration > Config.AccelPositiveThreshold then
            local accelFactor = MIN((acceleration - Config.AccelPositiveThreshold) / 200, 1.0)
            local accelDelay = Config.AccelPositiveDelay * accelFactor
            parryTime = parryTime + accelDelay
        elseif acceleration < Config.AccelNegativeThreshold then
            local accelFactor = MIN((ABS(acceleration) - ABS(Config.AccelNegativeThreshold)) / 200, 1.0)
            local accelAdvance = Config.AccelNegativeAdvance * accelFactor
            parryTime = parryTime + accelAdvance
        end
    end
    
    -- Apply multipliers
    parryTime = parryTime * distanceMultiplier
    parryTime = parryTime * progressiveDistMultiplier
    if speedAdjustment ~= 0 then
        parryTime = parryTime - speedAdjustment
    end
    
    -- PING-BASED COMPENSATION
    local pingOffset, pingMultiplier = GetPingBasedAdjustment(_G.AutoParryState.CurrentPing)
    parryTime = (parryTime * pingMultiplier) + pingOffset
    
    -- Curve compensation
    if isCurving and curveIntensity > 0 then
        local curveDirection = _G.AutoParryState.BallData.curveDirection or "towards"
        local baseCurveBonus = curveIntensity * Config.DeadZone * 0.22
        if curveDirection == "away" and speed > 150 then
            local speedFactor = MIN((speed - 150) / 500, 1.0)
            local awayCurveDelay = curveIntensity * Config.DeadZone * 1.1 * (1 + speedFactor * 0.7)
            if curveIntensity > 0.5 then awayCurveDelay = awayCurveDelay * 1.20 end
            if distance < 30 then awayCurveDelay = awayCurveDelay * 0.80 end
            parryTime = parryTime + awayCurveDelay
        elseif curveDirection == "towards" then
            if distance < 25 then baseCurveBonus = baseCurveBonus * 0.65 end
            parryTime = parryTime + baseCurveBonus
        else
            parryTime = parryTime + baseCurveBonus
        end
        if distance < 20 and curveDirection == "towards" then
            parryTime = parryTime * 1.18
        end
    end
    
    -- Distance-based adjustments
    if distance >= Config.LongRangeDistance then
        local longRangeMultiplier = 1.20
        if distance >= 100 then longRangeMultiplier = 1.30 end
        parryTime = parryTime * longRangeMultiplier
    elseif distance < Config.CloseRangeDistance then
        if speed > 400 then
            parryTime = parryTime * 0.98
        else
            parryTime = parryTime * 0.88
        end
    elseif distance >= Config.MidRangeStart and distance < Config.MidRangeEnd then
        if Config.MidRangeVelocityCompensation and speed >= Config.MidRangeVelocityThreshold then
            local speedExcess = speed - Config.MidRangeVelocityThreshold
            local velocityFactor = speedExcess * Config.MidRangeVelocityScale
            local compensation = Config.MidRangeBaseCompensation + velocityFactor
            compensation = MIN(compensation, Config.MidRangeMaxCompensation)
            local rangePosition = (distance - Config.MidRangeStart) / (Config.MidRangeEnd - Config.MidRangeStart)
            local rangeScale = 1.0 - (rangePosition * 0.30)
            compensation = compensation * rangeScale
            parryTime = parryTime - compensation
        end
    else
        if speed > 300 then parryTime = parryTime * 0.95 end
    end
    
    -- Rapid pass detection
    if _G.AutoParryState.BallData.isRapidPass and speed > 300 then
        local rapidPassBonus = (speed / 1000) * 0.25
        parryTime = parryTime + rapidPassBonus
    end
    
    -- Clamp to valid range
    parryTime = MAX(Config.MinParryTime, MIN(Config.MaxParryTime, parryTime))
    
    -- Track parry time
    table.insert(_G.AutoParryState.BallData.parryTimeHistory, parryTime)
    if #_G.AutoParryState.BallData.parryTimeHistory > 10 then
        table.remove(_G.AutoParryState.BallData.parryTimeHistory, 1)
    end
    
    return parryTime
end

