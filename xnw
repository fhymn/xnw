-- OPTIMIZED CURVE DETECTION (MATRIX STYLE)
-- ============================================
local function DetectCurve(ball, currentVelocity)
    if not ball or not currentVelocity then
        return false, 0, 0
    end
    
    local velocityHistory = _G.AutoParryState.BallData.velocityHistory
    local isCurving = false
    local curveIntensity = 0
    local lateralVelocity = 0
    
    pcall(function()
        table.insert(velocityHistory, currentVelocity)
        if #velocityHistory > Config.CurveHistorySize then
            table.remove(velocityHistory, 1)
        end
        
        local speed = VectorMagnitude(currentVelocity)
        if speed > 50 then
            local distance = _G.AutoParryState.BallData.distance or 50
            local detectionMethods = {}
            
            if #velocityHistory >= 2 then
                local lastVel = velocityHistory[#velocityHistory - 1]
                local velocityDelta = currentVelocity - lastVel
                local forwardDir = currentVelocity / speed
                local lateralChange = velocityDelta - (velocityDelta.X * forwardDir.X + velocityDelta.Y * forwardDir.Y + velocityDelta.Z * forwardDir.Z) * forwardDir
                lateralVelocity = VectorMagnitude(lateralChange)
                local baseIntensity = lateralVelocity / MAX(speed, 1)
                
                if distance < 25 then
                    local adjustedIntensity = baseIntensity * 1.6
                    if adjustedIntensity > (Config.CurveDetectionSensitivity * 0.6) then
                        detectionMethods.lateral = adjustedIntensity
                    end
                elseif distance < 50 then
                    local adjustedIntensity = baseIntensity * 1.1
                    if adjustedIntensity > Config.CurveDetectionSensitivity then
                        detectionMethods.lateral = adjustedIntensity
                    end
                else
                    if baseIntensity > (Config.CurveDetectionSensitivity * 1.2) then
                        detectionMethods.lateral = baseIntensity
                    end
                end
            end
            
            local angularVel = ball.AssemblyAngularVelocity or ZERO_VECTOR
            local spinMagnitude = SQRT(angularVel.X^2 + angularVel.Y^2 + angularVel.Z^2)
            if spinMagnitude > Config.CurveSpinThreshold and speed > 100 then
                local spinBonus = MIN(spinMagnitude / 50, 0.4)
                detectionMethods.spin = spinBonus
                if spinMagnitude > Config.CurveSpinHighThreshold then
                    detectionMethods.highSpin = 0.3
                end
            end
            
            if #velocityHistory >= 2 then
                local lastVel = velocityHistory[#velocityHistory - 1]
                local lastMag = VectorMagnitude(lastVel)
                if lastMag > 10 then
                    local lastDir = lastVel / lastMag
                    local currentDir = currentVelocity / speed
                    local dotProduct = CLAMP(lastDir.X * currentDir.X + lastDir.Y * currentDir.Y + lastDir.Z * currentDir.Z, -1, 1)
                    local directionChange = math.acos(dotProduct)
                    local angleThreshold = distance < 25 and Config.CurveAngleThreshold or Config.CurveAngleLongRange
                    if directionChange > angleThreshold then
                        detectionMethods.angle = directionChange * 1.8
                    end
                end
            end
            
            local curveDirection = "towards"
            local playerPos = GetPlayerPosition()
            if playerPos and distance < 50 then
                local ballPos = ball.Position
                local toBall = ballPos - playerPos
                local projectedPos = ballPos + currentVelocity * 0.1
                local projectedDist = VectorMagnitude(projectedPos - playerPos)
                if projectedDist > distance + 2 then
                    curveDirection = "away"
                    if speed > 150 then
                        detectionMethods.diverging_critical = 0.7
                    else
                        detectionMethods.diverging = 0.25
                    end
                elseif projectedDist < distance - 2 then
                    curveDirection = "towards"
                    if distance < 20 then
                        detectionMethods.converging = 0.15
                    end
                end
            end
            
            _G.AutoParryState.BallData.curveDirection = curveDirection
            
            local totalIntensity = 0
            local methodCount = 0
            for method, intensity in pairs(detectionMethods) do
                totalIntensity = totalIntensity + intensity
                methodCount = methodCount + 1
                isCurving = true
            end
            
            if methodCount > 0 then
                curveIntensity = totalIntensity
                if methodCount >= 2 then
                    curveIntensity = curveIntensity * 1.10
                end
                if methodCount >= 3 then
                    curveIntensity = curveIntensity * 1.20
                end
            end
            curveIntensity = MIN(curveIntensity, 1.8)
        end
        
        _G.AutoParryState.BallData.lastVelocity = currentVelocity
    end)
    
    return isCurving, curveIntensity, lateralVelocity
end

