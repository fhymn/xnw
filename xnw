            _G.AutoParryState.AbilityTracking.CurrentAbility = abilityStr
            return abilityStr
        end
        local character = player.Character
        if character then
            local charAbility = character:GetAttribute("EquippedAbility")
            if charAbility then
                local abilityStr = tostring(charAbility)
                _G.AutoParryState.AbilityTracking.CurrentAbility = abilityStr
                return abilityStr
            end
        end
    end
    return nil
