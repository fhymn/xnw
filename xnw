    if currentTime - _G.AutoParryState.AbilityTracking.LastAbilityCheck < 0.1 then
        return _G.AutoParryState.AbilityTracking.CurrentAbility
    end
    _G.AutoParryState.AbilityTracking.LastAbilityCheck = currentTime
