-- ============================================
-- ADAPTIVE AUTO-PARRY WITH RAPID-FIRE (PreLocal)
-- ============================================
RunService.PreLocal:Connect(function()
    if not _G.AutoParryState.ThreadRunning or not Config.AutoParryEnabled then
        return
    end
    pcall(function()
        local freezePhase = _G.AutoParryState.FreezeState.FreezePhase
        if freezePhase == "absolute_lock" then return end
        if _G.AutoParryState.BallData.isMidFlightFrozen then return end
        
        local clicked = _G.AutoParryState.Clicked
        local isTargeted = _G.AutoParryState.BallData.isTargeted
        
        if not isTargeted then
            _G.AutoParryState.AdaptiveRapidFire.InRapidFireMode = false
            _G.AutoParryState.AdaptiveRapidFire.ConsecutiveCloseFrames = 0
            _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = false
            _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = 999
            if clicked then _G.AutoParryState.Clicked = false end
            return
        end
        
        if _G.AutoParryState.ManualClashMode then return end
        
        local valid = _G.AutoParryState.BallData.valid
        if not valid then return end
        
        local distance = _G.AutoParryState.BallData.distance
        local speed = _G.AutoParryState.BallData.speed
        local ttr = _G.AutoParryState.BallData.timeToReach
        local parryTime = _G.AutoParryState.BallData.deadZoneAdjustedTime
        local shouldParry = _G.AutoParryState.BallData.shouldParry
        local currentTime = tick()
        
        if not _G.AutoParryState.BallData.hasApproached then
            if distance > 50 then return end
        end
        
        if speed < 200 and distance > 60 then return end
        
        local lastDistance = _G.AutoParryState.AdaptiveRapidFire.LastDistance
        local distanceIncreased = distance > lastDistance
        _G.AutoParryState.AdaptiveRapidFire.LastDistance = distance
        
        if distanceIncreased and (distance - lastDistance) > 5 then
            _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = false
            _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = 999
        end
        
        if _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall then
            if not (distance > _G.AutoParryState.AdaptiveRapidFire.LastParryDistance + 10) then
                return
            else
                _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = false
            end
        end
        
        if distanceIncreased then
            _G.AutoParryState.AdaptiveRapidFire.LastDistanceIncreaseTime = currentTime
        end
        
        local clicksPerFrame, useCalculatedTiming = GetRapidFireSettings(distance)
        
        if distance < 50 and speed >= 300 then
            local speedBonus = 0
            if speed >= 300 and speed < 500 then speedBonus = 2
            elseif speed >= 500 and speed < 700 then speedBonus = 3
            elseif speed >= 700 and speed < 1000 then speedBonus = 4
            elseif speed >= 1000 then speedBonus = 5 end
            clicksPerFrame = MIN(clicksPerFrame + speedBonus, 10)
        end
        
        local shouldBeInRapidFire = (clicksPerFrame > 1 or not useCalculatedTiming)
        local timeSinceDistanceIncrease = currentTime - _G.AutoParryState.AdaptiveRapidFire.LastDistanceIncreaseTime
        local isBackingAway = distanceIncreased or (timeSinceDistanceIncrease < Config.RapidFireDecayTime)
        
        if isBackingAway and _G.AutoParryState.AdaptiveRapidFire.InRapidFireMode and not shouldBeInRapidFire then
            local timeSinceLastClick = currentTime - _G.AutoParryState.AdaptiveRapidFire.LastClickTime
            if timeSinceLastClick < Config.RapidFireCooldown then return end
        end
        
        _G.AutoParryState.AdaptiveRapidFire.InRapidFireMode = shouldBeInRapidFire

        -- Try auto ability first
        local abilityFired = false
        if shouldParry and ttr <= parryTime then
            local equippedAbility = GetEquippedAbility()
            if equippedAbility then
                local al = equippedAbility:lower()
                if al:find("infinity") and Config.AutoPopAbilities.Infinity.enabled then
                    if UseAbility("Infinity") then abilityFired = true end
                elseif al:find("raging") and Config.AutoPopAbilities.RagingDeflection.enabled then
                    if UseAbility("RagingDeflection") then abilityFired = true end
                elseif al:find("calming") and Config.AutoPopAbilities.CalmingDeflection.enabled then
                    if UseAbility("CalmingDeflection") then abilityFired = true end
                elseif al:find("singularity") and Config.AutoPopAbilities.Singularity.enabled and Config.AutoPopAbilities.Singularity.useOnParry then
                    if UseAbility("Singularity") then abilityFired = true end
                elseif (al:find("aerodynamic") or al:find("aero")) and Config.AutoPopAbilities.AerodynamicSlash.enabled and Config.AutoPopAbilities.AerodynamicSlash.useOnParry then
                    if UseAbility("AerodynamicSlash") then abilityFired = true end
                elseif al:find("rapture") and Config.AutoPopAbilities.Rapture.enabled and Config.AutoPopAbilities.Rapture.useOnParry then
                    if UseAbility("Rapture") then abilityFired = true end
                elseif al:find("death") and Config.AutoPopAbilities.DeathSlash.enabled and Config.AutoPopAbilities.DeathSlash.useOnParry then
                    if UseAbility("DeathSlash") then abilityFired = true end
                elseif (al:find("fury") or al:find("slash of fury")) and Config.AutoPopAbilities.SlashOfFury.enabled and Config.AutoPopAbilities.SlashOfFury.useOnParry then
                    if UseAbility("SlashOfFury") then abilityFired = true end
                end
            end
        end

        if abilityFired then
            _G.AutoParryState.Clicked = true
            _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
            _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
            _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
            return
        end
        
        -- EMERGENCY PARRY
        if Config.EmergencyParryEnabled then
            if speed >= Config.EmergencySpeedThreshold then
                local emergencyThreshold = parryTime * 1.5
                if ttr <= emergencyThreshold then
                    for i = 1, clicksPerFrame do mouse1click() end
                    _G.AutoParryState.Clicked = true
                    _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
                    _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
                    _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
                    return
                end
            end
        end
        
        -- PREDICTIVE PARRY
        if Config.PredictiveParryEnabled and speed >= Config.PredictiveSpeedThreshold then
            local adjustedParryTime = parryTime * 1.2
            if shouldParry and ttr <= adjustedParryTime then
                for i = 1, clicksPerFrame do mouse1click() end
                _G.AutoParryState.Clicked = true
                _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
                _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
                _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
                return
            end
        end
        
        -- CLOSE RANGE INSTANT PARRY
        if Config.CloseRangeInstantParry and distance <= Config.CloseRangeInstantDistance then
            if ttr <= Config.CloseRangeInstantDelay then
                for i = 1, clicksPerFrame do mouse1click() end
                _G.AutoParryState.Clicked = true
                _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
                _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
                _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
                return
            end
        end
        
        -- ADAPTIVE PARRY
        if useCalculatedTiming then
            if shouldParry and ttr <= parryTime then
                if Config.AutoCurveEnabled and not AutoCurveState.IsFlicking then
                    DoAutoCurveFlick()
                else
                    for i = 1, clicksPerFrame do mouse1click() end
                end
                _G.AutoParryState.Clicked = true
                _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
                _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
                _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
            end
        else
            if shouldParry and distance <= 45 then
                if Config.AutoCurveEnabled and not AutoCurveState.IsFlicking then
                    DoAutoCurveFlick()
                else
                    for i = 1, clicksPerFrame do mouse1click() end
                end
                _G.AutoParryState.AdaptiveRapidFire.LastClickTime = currentTime
                if not _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall then
                    _G.AutoParryState.AdaptiveRapidFire.HasParriedThisBall = true
                    _G.AutoParryState.AdaptiveRapidFire.LastParryDistance = distance
                end
            end
        end
    end)
end)

