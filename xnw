-- RENDER LOOP (Drawing ONLY - Severe Best Practice)
-- ============================================
local playerPos = nil

RunService.Render:Connect(function()
    pcall(function()
        local cam = workspace.CurrentCamera
        if not cam then return end
        local vp = cam.ViewportSize
        local cx = vp.X * 0.5
        playerPos = GetPlayerPosition()
        
        -- poll window position for FPS widget
        pcall(function()
            local frame = Window.Frame
            if frame and frame.AbsolutePosition then
                _windowPos = frame.AbsolutePosition
            end
        end)
        
        -- ── FPS WIDGET ────────────────────────────────────────────
        if VisualsConfig.FPSEnabled then
            local now = tick()
            local dt = now - _fpsLastFrame
            _fpsLastFrame = now
            table.insert(_fpsSamples, dt)
            if #_fpsSamples > 30 then table.remove(_fpsSamples, 1) end
            local avg = 0
            for _, s in ipairs(_fpsSamples) do avg = avg + s end
            avg = avg / math.max(#_fpsSamples, 1)
            local fps = math.floor(1 / avg + 0.5)
            local fpsColor = VisualsConfig.FPSColor
            if fps < 30 then fpsColor = Color3.fromRGB(255, 60, 60)
            elseif fps < 60 then fpsColor = Color3.fromRGB(255, 165, 0) end
            local padding = 8
            local textSize = VisualsConfig.FPSTextSize
            local label = fps .. " FPS"
            local textW = #label * textSize * 0.55
            local panelW = textW + padding * 2
            local panelH = textSize + padding * 2
            local panelX = _windowPos.X + menuWidth + 6
            local panelY = _windowPos.Y
            local bg = _fpsWidget.bg
            bg.Position = Vector2.new(panelX, panelY)
            bg.Size = Vector2.new(panelW, panelH)
            bg.Color = Color3.fromRGB(18, 18, 28)
            bg.Opacity = 0.90
            bg.Visible = true
            local tx = _fpsWidget.text
            tx.Text = label
            tx.Color = fpsColor
            tx.Size = textSize
            tx.Position = Vector2.new(panelX + padding, panelY + padding)
            tx.Visible = true
        else
            _fpsWidget.bg.Visible = false
            _fpsWidget.text.Visible = false
        end
        
        -- ── PARRY CIRCLE ──────────────────────────────────────────
        -- FIX: Uses BallData.adaptiveParryTime (already calculated by PreLocal)
        -- instead of calling GetDynamicParryWindow which doesn't exist here.
        -- This means the circle is always in sync with the actual parry logic.
        if VisualsConfig.ParryCircleEnabled then
            local hrp = _G.AutoParryState.CachedHRP
            if hrp then
                local Ball = GetCurrentBall()
                local ballSpeed = 0
                local ballInRange = false
                local trueRadius = nil

                if Ball then
                    local bv = _G.GetBallVelocity(Ball)
                    ballSpeed = VectorMagnitude(bv)

                    if ballSpeed > Config.MinParrySpeed then
                        -- Use the already-computed adaptive parry window from BallData
                        local window = _G.AutoParryState.BallData.adaptiveParryTime
                        -- Apply scale factor so the visual circle is a practical indicator
                        -- rather than the full physics-sized threshold (which is huge at high speeds)
                        trueRadius = (ballSpeed * window + Config.ParryBufferDistance) * VisualsConfig.ParryCircleRadiusScale

                        -- Mirror parry fire condition using BallData values
                        local ttr = _G.AutoParryState.BallData.timeToReach
                        local timeSinceReset = tick() - (_G.AutoParryState.LastClickedResetTime or 0)
                        ballInRange = (ttr <= window) and (timeSinceReset >= 0.35)
                    end
                end

                -- Idle reference radius when no ball or ball too slow
                local idleRadius = 80 * Config.BaseParryTime + Config.ParryBufferDistance

                if not _parryCircleRadius then _parryCircleRadius = idleRadius end
                local targetRadius = trueRadius or idleRadius
                local lerpSpeed = trueRadius and 0.25 or 0.08
                _parryCircleRadius = _parryCircleRadius + (targetRadius - _parryCircleRadius) * lerpSpeed
                local radius = math.max(3, math.min(_parryCircleRadius, 200))

                local col = ballInRange and VisualsConfig.ParryCircleHitColor or VisualsConfig.ParryCircleColor
                local op = VisualsConfig.ParryCircleOpacity
                local th = VisualsConfig.ParryCircleThickness
                local groundY = hrp.Position.Y - 3
                local STEPS = 72
                local run = {}
                local function flushRun()
                    if #run >= 2 then
                        DrawingImmediate.Polyline(run, col, op, th)
                    end
                    run = {}
                end
                for i = 0, STEPS do
                    local angle = (i / STEPS) * math.pi * 2
                    local wx = hrp.Position.X + math.cos(angle) * radius
                    local wz = hrp.Position.Z + math.sin(angle) * radius
                    local sp, vis = cam:WorldToScreenPoint(Vector3.new(wx, groundY, wz))
                    if vis then
                        table.insert(run, vector.create(sp.X, sp.Y))
                    else
                        flushRun()
                    end
                end
                flushRun()
            end
        end
        
        -- ── BALL TRACER ───────────────────────────────────────────
        if VisualsConfig.BallTracerEnabled then
            local Ball = GetCurrentBall()
            if Ball then
                local screenBall, onScreen = cam:WorldToScreenPoint(Ball.Position)
                if onScreen then
                    DrawingImmediate.Line(
                        vector.create(cx, vp.Y),
                        vector.create(screenBall.X, screenBall.Y),
                        VisualsConfig.BallTracerColor,
                        VisualsConfig.BallTracerOpacity,
                        1,
                        VisualsConfig.BallTracerThickness
                    )
                end
            end
        end
        
        -- ── PLAYER BOXES ──────────────────────────────────────────
        if VisualsConfig.PlayerBoxesEnabled then
            local aliveFolder = workspace:FindFirstChild("Alive")
            local localName = _G.AutoParryState.LocalPlayer.Name
            if aliveFolder then
                for _, character in aliveFolder:GetChildren() do
                    if character.Name ~= localName then
                        local hrp = character:FindFirstChild("HumanoidRootPart")
                        local head = character:FindFirstChild("Head")
                        if hrp and head then
                            local topWorld = head.Position + Vector3.new(0, 0.8, 0)
                            local bottomWorld = hrp.Position - Vector3.new(0, 3.0, 0)
                            local topScreen, topVis = cam:WorldToScreenPoint(topWorld)
                            local bottomScreen, bottomVis = cam:WorldToScreenPoint(bottomWorld)
                            if topVis and bottomVis then
                                local height = math.abs(bottomScreen.Y - topScreen.Y)
                                local width = height * 0.5
                                local left = topScreen.X - width * 0.5
                                local top = topScreen.Y
                                local col = VisualsConfig.PlayerBoxColor
                                local op = VisualsConfig.PlayerBoxOpacity
                                local th = VisualsConfig.PlayerBoxThickness
                                if VisualsConfig.PlayerBoxFilled then
                                    DrawingImmediate.FilledRectangle(
                                        vector.create(left, top),
                                        vector.create(width, height),
                                        VisualsConfig.PlayerBoxFillColor,
                                        VisualsConfig.PlayerBoxFillOpacity
                                    )
                                end
                                DrawingImmediate.Rectangle(
                                    vector.create(left, top),
                                    vector.create(width, height),
                                    col, op, 0, th
                                )
                            end
                        end
                    end
                end
            end
        end
        
        -- ── BALL STATS ────────────────────────────────────────────
        -- Shows distance, speed, and active mode label above the ball
        if VisualsConfig.BallStatsEnabled then
            local Ball = GetCurrentBall()
            if Ball and playerPos then
                local screenPos, onScreen = cam:WorldToScreenPoint(Ball.Position)
                if onScreen then
                    local distance = math.floor(VectorMagnitude(Ball.Position - playerPos))
                    local ballVel = _G.GetBallVelocity(Ball)
                    local speed = math.floor(VectorMagnitude(ballVel))
                    local yOffset = -60

                    -- Pick color and label based on active mode
                    local distColor = ESPSettings.DistanceColor
                    local displayText = distance .. " studs | " .. speed .. " speed"

                    if _G.AutoParryState.ManualClashMode then
                        distColor = Color3.fromRGB(255, 100, 255)
                        displayText = "⚡ MANUAL CLASH | " .. distance .. " studs"
                    elseif Config.AutoCurveEnabled then
                        distColor = Color3.fromRGB(0, 220, 255)
                        displayText = "〜 AUTO CURVE | " .. distance .. " studs"
                    elseif distance <= 30 then
                        distColor = Color3.fromRGB(255, 50, 50)
                    elseif distance <= 45 then
                        distColor = Color3.fromRGB(255, 165, 0)
                    elseif distance <= 70 then
                        distColor = Color3.fromRGB(255, 255, 0)
                    end

                    DrawingImmediate.OutlinedText(
                        vector.create(screenPos.X, screenPos.Y + yOffset),
                        14,
                        distColor,
                        1,
                        displayText,
                        true,
                        nil
                    )
                end
            end
        end

        -- ── ABILITY ESP ───────────────────────────────────────────
        -- Ported from old script: shows ability name + distance above each enemy's head.
        -- Uses _ESPAbilityCache to persist last known ability when attribute temporarily reads nil.
        if ESPSettings.Enabled then
            local localName = _G.AutoParryState.LocalPlayer.Name
            local aliveFolder = workspace:FindFirstChild("Alive")
            if aliveFolder then
                -- Clean cache of players who left
                local alivePlayerNames = {}
                for _, character in aliveFolder:GetChildren() do
                    alivePlayerNames[character.Name] = true
                end
                for cachedName, _ in pairs(_ESPAbilityCache) do
                    if not alivePlayerNames[cachedName] then
                        _ESPAbilityCache[cachedName] = nil
                    end
                end

                for _, character in aliveFolder:GetChildren() do
                    local playerName = character.Name
                    if playerName ~= localName then
                        local head = character:FindFirstChild("Head")
                        if head then
                            local headPos = head.Position + Vector3.new(0, 2, 0)
                            local screenPos, onScreen = cam:WorldToScreenPoint(headPos)
                            if onScreen then
                                -- Try player attribute first, then character attribute
                                local abilityText = nil
                                local player = Players:FindFirstChild(playerName)
                                if player then
                                    local equippedAbility = player:GetAttribute("EquippedAbility")
                                    if equippedAbility and tostring(equippedAbility) ~= "" then
                                        abilityText = tostring(equippedAbility)
                                    end
                                end
                                if not abilityText then
                                    local charAbility = character:GetAttribute("EquippedAbility")
                                    if charAbility and tostring(charAbility) ~= "" then
                                        abilityText = tostring(charAbility)
                                    end
                                end
                                -- Also check HRP attribute as fallback
                                if not abilityText then
                                    local hrpInner = character:FindFirstChild("HumanoidRootPart")
                                    if hrpInner then
                                        local hrpAbility = hrpInner:GetAttribute("EquippedAbility")
                                        if hrpAbility and tostring(hrpAbility) ~= "" then
                                            abilityText = tostring(hrpAbility)
                                        end
                                    end
                                end
                                -- Update cache if we got a fresh value, otherwise use cached
                                if abilityText and abilityText ~= "" then
                                    _ESPAbilityCache[playerName] = abilityText
                                else
                                    abilityText = _ESPAbilityCache[playerName]
                                end

                                -- Draw ability name
                                if abilityText and abilityText ~= "" then
                                    DrawingImmediate.OutlinedText(
                                        vector.create(screenPos.X, screenPos.Y - 20),
                                        ESPSettings.TextSize,
                                        ESPSettings.AbilityColor,
                                        ESPSettings.Opacity,
                                        abilityText,
                                        true,
                                        nil
                                    )
                                end

                                -- Draw distance
                                if ESPSettings.ShowDistance and playerPos then
                                    local hrpInner = character:FindFirstChild("HumanoidRootPart")
                                    if hrpInner then
                                        local dist = math.floor(VectorMagnitude(hrpInner.Position - playerPos))
                                        DrawingImmediate.OutlinedText(
                                            vector.create(screenPos.X, screenPos.Y - 5),
                                            12,
                                            ESPSettings.DistanceColor,
                                            0.8,
                                            dist .. " studs",
                                            true,
                                            nil
                                        )
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end)

