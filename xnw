local function RenderColorPicker(mx, my, lDown, prevLMB)
    if Menu.PickerOpenID == 0 then return end

    local curH, curS, curV = GetPickerColor(Menu.PickerOpenID)

    local svSize = 150
    local hueBarH = 14
    local gap = 6
    local popPad = 8
    local popHeaderH = 22
    local popW = popPad * 2 + svSize
    local popH = popHeaderH + popPad + svSize + gap + hueBarH + popPad
    local popX = Menu.PickerAnchorX - popW
    local popY = Menu.PickerAnchorY

    DrawMenuRect(popX, popY, popW, popH, 0, 0, 0)
    DrawMenuRect(popX + 1, popY + 1, popW - 2, popH - 2, 50, 50, 50)
    DrawMenuRect(popX + 2, popY + 2, popW - 4, popH - 4, 25, 25, 25)

    local cpTs = GetTextSize(Menu.PickerTitle)
    DrawTextShadow(Menu.PickerTitle, popX + (popW / 2) - (cpTs.X / 2), popY + 5, 220, 220, 220, 255, 0, 0, 0, 255)
    DrawMenuRect(popX + 4, popY + popHeaderH, popW - 8, 1, 255, 255, 255, 25)

    local svX = popX + popPad
    local svY = popY + popHeaderH + popPad

    local hueR, hueG, hueB = HSVtoRGB(curH, 1, 1)
    DrawMenuRect(svX, svY, svSize, svSize, hueR, hueG, hueB)

    local strips = math.floor(svSize)
    for i = 0, strips - 1 do
        local a = 255 - math.floor(i * 255 / (strips - 1))
        if a < 0 then a = 0 end
        DrawMenuRect(svX + i, svY, 2, svSize, 255, 255, 255, a)
    end

    for i = 0, strips - 1 do
        local a = math.floor(i * 255 / (strips - 1))
        if a > 255 then a = 255 end
        DrawMenuRect(svX, svY + i, svSize, 2, 0, 0, 0, a)
    end

    DrawMenuBorder(svX - 1, svY - 1, svSize + 2, svSize + 2, 0, 0, 0)

    local crossX = svX + curS * svSize
    local crossY = svY + (1 - curV) * svSize
    DrawCircle(crossX, crossY, 5, 0, 0, 0, 200, 1.5, false)
    DrawCircle(crossX, crossY, 4, 255, 255, 255, 255, 1.5, false)

    local hbX = svX
    local hbY = svY + svSize + gap
    local hueStrips = math.floor(svSize)
    for i = 0, hueStrips - 1 do
        local hVal = i / (hueStrips - 1) * 360
        local hr, hg, hb = HSVtoRGB(hVal, 1, 1)
        DrawMenuRect(hbX + i, hbY, 2, hueBarH, hr, hg, hb)
    end
    DrawMenuBorder(hbX - 1, hbY - 1, svSize + 2, hueBarH + 2, 0, 0, 0)

    local hueMarkerX = hbX + (curH / 360) * svSize
    DrawMenuRect(hueMarkerX - 2, hbY - 2, 4, hueBarH + 4, 0, 0, 0, 200)
    DrawMenuRect(hueMarkerX - 1, hbY - 1, 2, hueBarH + 2, 255, 255, 255)

    local hoverSV = mx >= svX and mx <= svX + svSize and my >= svY and my <= svY + svSize
    local hoverHue = mx >= hbX and mx <= hbX + svSize and my >= hbY - 2 and my <= hbY + hueBarH + 2

    if lDown and Menu.PickerDrag == 0 then
        if hoverSV then Menu.PickerDrag = 1
        elseif hoverHue then Menu.PickerDrag = 2
        end
    end
    if not lDown then Menu.PickerDrag = 0 end

    if Menu.PickerDrag == 1 then
        curS = math.max(0, math.min(1, (mx - svX) / svSize))
        curV = math.max(0, math.min(1, 1 - (my - svY) / svSize))
    elseif Menu.PickerDrag == 2 then
        curH = math.max(0, math.min(359.9, (mx - hbX) / svSize * 360))
    end

    SetPickerColor(Menu.PickerOpenID, curH, curS, curV)

    if Menu.PickerJustOpened then
        Menu.PickerJustOpened = false
    elseif lDown and not prevLMB and Menu.PickerDrag == 0 then
        local insidePop = mx >= popX and mx <= popX + popW and my >= popY and my <= popY + popH
        if not insidePop then Menu.PickerOpenID = 0 end
    end
end

local function ProcessKeybindListening()
    if Menu.ListeningKB >= 0 then
        if Menu.ListeningSkip then
            if not isleftpressed() then Menu.ListeningSkip = false end
        else
            if IsKeyDown("Escape") then
                Menu.ListeningKB = -1
            elseif IsKeyDown("Backspace") then
                Keybinds[Menu.ListeningKB] = ""
                KeybindActive[Menu.ListeningKB] = true
                Menu.ListeningKB = -1
            else
                local foundKey = GetAnyPressedKey()
                if foundKey then
                    Keybinds[Menu.ListeningKB] = foundKey
                    KeybindActive[Menu.ListeningKB] = true
                    Menu.ListeningKB = -1
                end
            end
        end
    end

    if Menu.ListeningMenuKey then
        if Menu.ListeningMenuKeySkip then
            if not isleftpressed() then Menu.ListeningMenuKeySkip = false end
        else
            if IsKeyDown("Escape") then
                Menu.ListeningMenuKey = false
            elseif IsKeyDown("Backspace") then
                Menu.MenuKey = "End"
                Menu.ListeningMenuKey = false
            else
                local foundKey = GetAnyPressedKey()
                if foundKey then
                    Menu.MenuKey = foundKey
                    Menu.ListeningMenuKey = false
                    Menu.PrevInsert = true
                end
            end
        end
    end
end

local function UpdateKeybindStates()
    if Menu.ListeningKB >= 0 then return end

    for ki = 1, MAX_KEYBINDS do
        if KeybindMode[ki] == 2 then
            -- Always On: no toggle notification needed
            KeybindActive[ki] = true
        elseif Keybinds[ki] ~= "" then
            local kd = IsKeyDown(Keybinds[ki])
            if KeybindMode[ki] == 0 then
                -- Hold mode: notify on press and release edges
                if kd ~= PrevKeyStates[ki] then
                    local settingKey = KEYBIND_SETTING_KEYS[ki]
                    if settingKey and Settings[settingKey] then
                        -- Only notify if the feature itself is enabled
                        if kd then
                            NotifyOn(KEYBIND_NAMES[ki])
                        else
                            NotifyOff(KEYBIND_NAMES[ki])
                        end
                    end
                end
                KeybindActive[ki] = kd
            else
                -- Toggle mode: notify on the toggle edge
                if kd and not PrevKeyStates[ki] then
                    local newState = not KeybindActive[ki]
                    KeybindActive[ki] = newState
                    local settingKey = KEYBIND_SETTING_KEYS[ki]
                    if settingKey and Settings[settingKey] then
                        if newState then
                            NotifyOn(KEYBIND_NAMES[ki])
                        else
                            NotifyOff(KEYBIND_NAMES[ki])
                        end
                    end
                end
            end
            PrevKeyStates[ki] = kd
        else
            PrevKeyStates[ki] = false
        end
    end
end

local function RenderKeybindList(mx, my, lDown)
    if not Menu.ShowKeybindList then return end

    local featureEnabled = {
        Settings.AutoParryEnabled,
        Settings.BBTriggerbotEnabled,
        Settings.AutoClickEnabled,
        Settings.ManualClashEnabled,
        Settings.AutoCurveEnabled,
    }
    local kbFrameW = 180
    local kbLineH = 16
    local kbPad = 6
    local kbHeaderH = 22

    local boundCount = 0
    for ki = 1, MAX_KEYBINDS do
        if featureEnabled[ki] and (Keybinds[ki] ~= "" or KeybindMode[ki] == 2) then
            boundCount = boundCount + 1
        end
    end

    local kbContentH = boundCount > 0 and (boundCount * kbLineH) or 18
    local kbTotalH = kbHeaderH + kbPad + kbContentH

    if Menu.KBListX < 0 then
        Menu.KBListX = Menu.X - kbFrameW - 4
        Menu.KBListY = Menu.Y
    end

    local kbX = Menu.KBListX
    local kbY = Menu.KBListY

    DrawMenuRect(kbX, kbY, kbFrameW, kbTotalH, 0, 0, 0)
    DrawMenuRect(kbX + 1, kbY + 1, kbFrameW - 2, kbTotalH - 2, 50, 50, 50)
    DrawMenuRect(kbX + 2, kbY + 2, kbFrameW - 4, kbTotalH - 4, 25, 25, 25)

    if Menu.Open then
        local kbHeaderH2 = 22
        if lDown and not Menu.KBListDragging and not Menu.Dragging then
            local hoverHeader = mx >= kbX and mx <= kbX + kbFrameW and my >= kbY and my <= kbY + kbHeaderH2
            if hoverHeader then
                Menu.KBListDragging = true
                Menu.KBListDragOffX = mx - kbX
                Menu.KBListDragOffY = my - kbY
            end
        end
        if Menu.KBListDragging then
            Menu.KBListX = mx - Menu.KBListDragOffX
            Menu.KBListY = my - Menu.KBListDragOffY
        end
    end
    if not lDown then Menu.KBListDragging = false end

    local kbTitle = "KEYBINDS"
    local kbTitleSz = GetTextSize(kbTitle)
    DrawTextShadow(kbTitle, kbX + (kbFrameW / 2) - (kbTitleSz.X / 2), kbY + 5, 220, 220, 220, 255, 0, 0, 0, 255)
    DrawMenuRect(kbX + 4, kbY + kbHeaderH, kbFrameW - 8, 1, 255, 255, 255, 25)

    local kbListY = kbY + kbHeaderH + kbPad / 2
    if boundCount > 0 then
        local rowIdx = 0
        for ki = 1, MAX_KEYBINDS do
            if featureEnabled[ki] and (Keybinds[ki] ~= "" or KeybindMode[ki] == 2) then
                local rowY = kbListY + rowIdx * kbLineH
                local active = KeybindActive[ki]
                local cr, cg, cb = 100, 100, 100
                if active then cr, cg, cb = 240, 240, 240 end

                DrawTextShadow(KEYBIND_NAMES[ki], kbX + kbPad, rowY + 1, cr, cg, cb, 255, 0, 0, 0, 255)

                local keyTxt
                if KeybindMode[ki] == 2 then
                    keyTxt = "[Always On]"
                else
                    keyTxt = "[" .. KeyToDisplay(Keybinds[ki]) .. "]"
                end
                local keySz = GetTextSize(keyTxt)
                DrawTextShadow(keyTxt, kbX + kbFrameW - keySz.X - kbPad, rowY + 1, cr, cg, cb, 255, 0, 0, 0, 255)
                rowIdx = rowIdx + 1
            end
        end
    else
        local emptyTxt = "No keybinds"
        local emptySz = GetTextSize(emptyTxt)
        DrawTextShadow(emptyTxt, kbX + (kbFrameW / 2) - (emptySz.X / 2), kbListY + 2, 100, 100, 100, 255, 0, 0, 0, 255)
    end
end

