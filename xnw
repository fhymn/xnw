local function AP_PressQKey()
    keypress(0x51)
    keyrelease(0x51)
end

local function AP_GetEquippedAbility()
    local currentTime = tick()
    if currentTime - AutoPop_Tracking.LastAbilityCheck < 0.1 then
        return AutoPop_Tracking.CurrentAbility
    end
    AutoPop_Tracking.LastAbilityCheck = currentTime
    local ability = LocalPlayer:GetAttribute("EquippedAbility")
    if ability then
        local abilityStr = tostring(ability)
        AutoPop_Tracking.CurrentAbility = abilityStr
        return abilityStr
    end
    local character = LocalPlayer.Character
    if character then
        local charAbility = character:GetAttribute("EquippedAbility")
        if charAbility then
            local abilityStr = tostring(charAbility)
            AutoPop_Tracking.CurrentAbility = abilityStr
            return abilityStr
        end
    end
    return nil
end

local function AP_CanUseAbility(abilityName)
    local currentTime = tick()
    local cooldownEnd = AutoPop_Tracking.AbilityCooldowns[abilityName] or 0
    if currentTime < cooldownEnd then return false end
    if currentTime - AutoPop_Tracking.LastAutoPop < 0.2 then return false end
    return true
end

local function AP_UseAbility(abilityName)
    if not AP_CanUseAbility(abilityName) then return false end
    local currentTime = tick()
    AP_PressQKey()
    local cd = AutoPop_CooldownDurations[abilityName] or 20
    AutoPop_Tracking.AbilityCooldowns[abilityName] = currentTime + cd
    AutoPop_Tracking.LastAutoPop = currentTime
    return true
end

-- Curve detection state
local CD_velocityHistory = {}
local CD_curveDirection = "towards"
local CD_lastBall = nil
local CD_HISTORY_SIZE = 5
local CD_SENSITIVITY = 0.15
local CD_SPIN_THRESHOLD = 15
local CD_SPIN_HIGH_THRESHOLD = 30
local CD_ANGLE_THRESHOLD = 0.08
local CD_ANGLE_LONG_RANGE = 0.12
local CD_DEADZONE = 2.2

local function DetectCurve(ball, currentVelocity, distance)
    if not ball or not currentVelocity then return false, 0 end
    if ball ~= CD_lastBall then
        CD_velocityHistory = {}
        CD_curveDirection = "towards"
        CD_lastBall = ball
    end
    local isCurving = false
    local curveIntensity = 0
    pcall(function()
        table.insert(CD_velocityHistory, currentVelocity)
        if #CD_velocityHistory > CD_HISTORY_SIZE then table.remove(CD_velocityHistory, 1) end
        local speed = math.sqrt(currentVelocity.X^2 + currentVelocity.Y^2 + currentVelocity.Z^2)
        if speed > 50 then
            local detectionMethods = {}
            if #CD_velocityHistory >= 2 then
                local lastVel = CD_velocityHistory[#CD_velocityHistory - 1]
                local velocityDelta = currentVelocity - lastVel
                local forwardDir = currentVelocity / speed
                local fwdDot = velocityDelta.X*forwardDir.X + velocityDelta.Y*forwardDir.Y + velocityDelta.Z*forwardDir.Z
                local latX = velocityDelta.X - fwdDot*forwardDir.X
                local latY = velocityDelta.Y - fwdDot*forwardDir.Y
                local latZ = velocityDelta.Z - fwdDot*forwardDir.Z
                local lateralVelocity = math.sqrt(latX^2 + latY^2 + latZ^2)
                local baseIntensity = lateralVelocity / math.max(speed, 1)
                if distance < 25 then
                    local adj = baseIntensity * 1.6
                    if adj > CD_SENSITIVITY * 0.6 then detectionMethods.lateral = adj end
                elseif distance < 50 then
                    local adj = baseIntensity * 1.1
                    if adj > CD_SENSITIVITY then detectionMethods.lateral = adj end
                else
                    if baseIntensity > CD_SENSITIVITY * 1.2 then detectionMethods.lateral = baseIntensity end
                end
            end
            local ok, angVel = pcall(function() return ball.AssemblyAngularVelocity end)
            if ok and angVel then
                local spinMag = math.sqrt(angVel.X^2 + angVel.Y^2 + angVel.Z^2)
                if spinMag > CD_SPIN_THRESHOLD and speed > 100 then
                    detectionMethods.spin = math.min(spinMag / 50, 0.4)
                    if spinMag > CD_SPIN_HIGH_THRESHOLD then detectionMethods.highSpin = 0.3 end
                end
            end
            if #CD_velocityHistory >= 2 then
                local lastVel = CD_velocityHistory[#CD_velocityHistory - 1]
                local lastMag = math.sqrt(lastVel.X^2 + lastVel.Y^2 + lastVel.Z^2)
                if lastMag > 10 then
                    local lastDir = lastVel / lastMag
                    local curDir = currentVelocity / speed
                    local dp = math.max(-1, math.min(1, lastDir.X*curDir.X + lastDir.Y*curDir.Y + lastDir.Z*curDir.Z))
                    local dirChange = math.acos(dp)
                    local angleThresh = distance < 25 and CD_ANGLE_THRESHOLD or CD_ANGLE_LONG_RANGE
                    if dirChange > angleThresh then detectionMethods.angle = dirChange * 1.8 end
                end
            end
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local lookahead = distance < 50 and 0.1 or math.min(distance / speed, 0.5)
                local proj = ball.Position + currentVelocity * lookahead
                local projDist = math.sqrt((proj.X-hrp.Position.X)^2+(proj.Y-hrp.Position.Y)^2+(proj.Z-hrp.Position.Z)^2)
                local threshold = distance < 50 and 2 or math.max(2, distance * 0.04)
                if projDist > distance + threshold then
                    CD_curveDirection = "away"
                    if speed > 150 then detectionMethods.diverging_critical = 0.7
                    else detectionMethods.diverging = 0.25 end
                elseif projDist < distance - threshold then
                    CD_curveDirection = "towards"
                    if distance < 20 then detectionMethods.converging = 0.15 end
                end
            end
            local total, count = 0, 0
            for _, v in pairs(detectionMethods) do total = total + v; count = count + 1; isCurving = true end
            if count > 0 then
                curveIntensity = total
                if count >= 2 then curveIntensity = curveIntensity * 1.10 end
                if count >= 3 then curveIntensity = curveIntensity * 1.20 end
            end
            curveIntensity = math.min(curveIntensity, 1.8)
        end
    end)
    return isCurving, curveIntensity
end

