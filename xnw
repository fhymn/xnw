local _running = true

local _ESPAbilityCache = {}
local _parryCircleRadius = nil
local _fpsSamples = {}
local _fpsLastFrame = os.clock()

local function OnRender()
    if not _running then return end

    RefreshPressedKeys()

    local mousePos = UserInputService:GetMouseLocation()
    local mx, my = mousePos.X, mousePos.Y
    local lDown = isleftpressed()
    local rDown = isrightpressed()
    local insertDown = IsKeyDown(Menu.MenuKey)

    if insertDown and not Menu.PrevInsert and not Menu.ListeningMenuKey then
        Menu.Open = not Menu.Open
    end
    Menu.PrevInsert = insertDown

    UpdateKeybindStates()

    ProcessKeybindListening()

    do
        local ball = GetBall()
        local targeting = ball and IsBallTargetingMe(ball)

        if not targeting then
            TB_HasClicked = false
            AP_HasClicked = false
            AP_TrackedBall = nil
            AP_LastTargetName = nil
            AutoPop_FiredThisBall = false
            AP_LastDistance = 999
            AP_HasApproached = false
            AP_LastParryDistance = 999
            AP_PeakBallSpeed = 0
            AP_HasParriedThisBall = false
            AP_ParryFiredDistance = 999
        end

        if targeting and ball then
            local curTarget = nil
            pcall(function() curTarget = ball:GetAttribute("target") end)
            local curTargetName = curTarget and tostring(curTarget) or nil

            if ball ~= AP_TrackedBall then
                AP_TrackedBall = ball
                AP_LastTargetName = curTargetName
                AutoPop_FiredThisBall = false
                AP_LastDistance = 999
                AP_HasApproached = false
                AP_LastParryDistance = 999
                AP_PeakBallSpeed = 0
                AP_HasParriedThisBall = false
                AP_ParryFiredDistance = 999
            elseif curTargetName ~= AP_LastTargetName then
                AP_HasClicked = false
                AP_LastTargetName = curTargetName
                AutoPop_FiredThisBall = false
                AP_LastDistance = 999
                AP_HasApproached = false
                AP_LastParryDistance = 999
                AP_HasParriedThisBall = false
                AP_ParryFiredDistance = 999
            end
        end

        local apActive = Settings.AutoParryEnabled and KeybindActive[1]
        local tbActive = Settings.BBTriggerbotEnabled and KeybindActive[2]

        if targeting and (apActive or tbActive) and IsPlayerAlive() and not HasSingularityCape()
           and not ball:FindFirstChild("ComboCounter") then
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")

            if hrp then
                local velX, velY, velZ = 0, 0, 0
                local ballSpeed = 0
                local zoomies = ball:FindFirstChild("zoomies")
                if zoomies then
                    local ok, zvel = pcall(function() return zoomies.VectorVelocity end)
                    if ok and zvel then
                        velX, velY, velZ = zvel.X, zvel.Y, zvel.Z
                        ballSpeed = math.sqrt(velX * velX + velY * velY + velZ * velZ)
                    end
                end
                if ballSpeed < 0.1 then
                    local vel = ball.Velocity
                    velX, velY, velZ = vel.X, vel.Y, vel.Z
                    ballSpeed = math.sqrt(velX * velX + velY * velY + velZ * velZ)
                end

                local ballPos = ball.Position
                local hrpPos = hrp.Position
                local px, py, pz = hrpPos.X, hrpPos.Y, hrpPos.Z
                local bx, by, bz = ballPos.X, ballPos.Y, ballPos.Z

                local dx, dy, dz = bx - px, by - py, bz - pz
                local distToPlayer = math.sqrt(dx * dx + dy * dy + dz * dz)

                if distToPlayer > AP_LastParryDistance + 15 then
                    AP_HasApproached = false
                    AP_LastParryDistance = 999
                end
                if distToPlayer < AP_LastDistance then
                    AP_HasApproached = true
                end
                AP_LastDistance = distToPlayer

                local velVec = Vector3.new(velX, velY, velZ)
                local isCurving, curveIntensity = DetectCurve(ball, velVec, distToPlayer)

                local nowMs = os.clock()

                if apActive then
                    -- If ball moved 10+ studs away from where we parried, it bounced
                    -- off someone else and is now a new threat — allow parry again
                    if AP_HasParriedThisBall then
                        if distToPlayer > AP_ParryFiredDistance + 10 then
                            AP_HasParriedThisBall = false
                            AP_HasClicked = false
                            AP_ParryFiredDistance = 999
                        end
                    end

                    if not AP_HasParriedThisBall then
                        local toBallX, toBallY, toBallZ = dx, dy, dz
                        local toPlayerX, toPlayerY, toPlayerZ = -dx, -dy, -dz
                        local toPlayerLen = distToPlayer
                        local suppress = false
                        if distToPlayer > 0.01 and ballSpeed > 0.01 then
                            local tpNX = -dx / distToPlayer
                            local tpNY = -dy / distToPlayer
                            local tpNZ = -dz / distToPlayer
                            local vNX = velX / ballSpeed
                            local vNY = velY / ballSpeed
                            local vNZ = velZ / ballSpeed
                            local dot = vNX*tpNX + vNY*tpNY + vNZ*tpNZ
                            -- Scale threshold with speed so fast incoming balls are never suppressed
                            local threshold
                            if ballSpeed >= 400 then threshold = -0.35
                            elseif ballSpeed >= 200 then threshold = -0.20
                            else threshold = -0.10 end
                            if dot < threshold then suppress = true end
                        end
                        -- Only suppress curve-away at high confidence
                        if not suppress then
                            suppress = isCurving and CD_curveDirection == "away" and curveIntensity > 0.7
                        end

                        if not suppress then
                            -- Track peak speed from 800+ so tier multiplier
                            -- sticks even if ball slows slightly on approach
                            if ballSpeed >= 800 then
                                AP_PeakBallSpeed = math.max(AP_PeakBallSpeed, ballSpeed)
                            end

                            -- Divisor uses actual ballSpeed (not peak) so parryDist
                            -- stays proportional to current speed and lockout stays valid
                            local cappedSpeedDiff = math.max(math.min(ballSpeed - 9.5, 500), 0)
                            local speedDivisorBase = 2.4 + cappedSpeedDiff * 0.0015
                            if ballSpeed > 500 then
                                local reduction = math.min((ballSpeed - 500) * 0.0008, 0.5)
                                speedDivisorBase = math.max(speedDivisorBase - reduction, 1.8)
                            end

                            local multiplier = 0.7 + (Settings.AccuracyRange - 1) * (0.35 / 99)
                            if Settings.RandomAccuracy then
                                if ballSpeed < 200 then
                                    multiplier = 0.7 + (math.random(40, 100) - 1) * (0.35 / 99)
                                else
                                    multiplier = 0.7 + (math.random(1, 100) - 1) * (0.35 / 99)
                                end
                            end

                            local speedDivisor = speedDivisorBase * multiplier
                            local speedComponent = math.max(ballSpeed / speedDivisor, 9.5)

                            local ping = GetPing() / 10
                            local pingThreshold = math.max(5, math.min(ping / 10, 17))
                            local parryDist = pingThreshold + speedComponent

                            -- Tiered multipliers based on peak speed (sticky at 800+)
                            -- so the window stays large even as ball slightly decelerates
                            local speedTier = math.max(ballSpeed, AP_PeakBallSpeed)
                            if speedTier >= 1000 then
                                parryDist = parryDist * 1.55
                            elseif speedTier >= 900 then
                                parryDist = parryDist * 1.40
                            elseif speedTier >= 700 then
                                parryDist = parryDist * 1.25
                            elseif speedTier >= 500 then
                                parryDist = parryDist * 1.12
                            end

                            if Settings.CurveDetectionEnabled and isCurving and curveIntensity > 0 and CD_curveDirection == "towards" then
                                local curveDelay = curveIntensity * CD_DEADZONE * 0.22
                                if distToPlayer < 25 then curveDelay = curveDelay * 0.65 end
                                parryDist = parryDist * math.max(0.4, 1 - math.min(curveDelay * 0.35, 0.6))
                            end

                            if distToPlayer <= parryDist and not AP_HasParriedThisBall then
                                local abilityFired = false
                                if not AutoPop_FiredThisBall then
                                    local equippedAbility = AP_GetEquippedAbility()
                                    if equippedAbility then
                                        local al = equippedAbility:lower()
                                        if al:find("infinity") and Settings.AutoPop_Infinity then
                                            if AP_UseAbility("Infinity") then abilityFired = true end
                                        elseif al:find("raging") and Settings.AutoPop_RagingDeflection then
                                            if AP_UseAbility("RagingDeflection") then abilityFired = true end
                                        elseif al:find("calming") and Settings.AutoPop_CalmingDeflection then
                                            if AP_UseAbility("CalmingDeflection") then abilityFired = true end
                                        elseif al:find("singularity") and Settings.AutoPop_Singularity then
                                            if AP_UseAbility("Singularity") then abilityFired = true end
                                        elseif (al:find("aerodynamic") or al:find("aero")) and Settings.AutoPop_AerodynamicSlash then
                                            if AP_UseAbility("AerodynamicSlash") then abilityFired = true end
                                        elseif al:find("rapture") and Settings.AutoPop_Rapture then
                                            if AP_UseAbility("Rapture") then abilityFired = true end
                                        elseif al:find("death") and Settings.AutoPop_DeathSlash then
                                            if AP_UseAbility("DeathSlash") then abilityFired = true end
                                        elseif (al:find("fury") or al:find("slash of fury")) and Settings.AutoPop_SlashOfFury then
                                            if AP_UseAbility("SlashOfFury") then abilityFired = true end
                                        end
                                    end
                                end
                                if abilityFired then
                                    AutoPop_FiredThisBall = true
                                    AP_HasClicked = true
                                    AP_LastParryTime = nowMs
                                    AP_LastParryDistance = distToPlayer
                                    AP_HasParriedThisBall = true
                                    AP_ParryFiredDistance = distToPlayer
                                else
                                    mouse1click()
                                    AP_HasClicked = true
                                    AP_LastParryTime = nowMs
                                    AP_LastParryDistance = distToPlayer
                                    AP_HasParriedThisBall = true
                                    AP_ParryFiredDistance = distToPlayer
                                end
                            end
                        end
                    end
                elseif tbActive then
                    if not TB_HasClicked
                       and ballSpeed >= Settings.BBMinBallSpeed
                       and nowMs - TB_LastClickTime >= Settings.BBTriggerDelay / 1000 then
                        mouse1click()
                        TB_LastClickTime = nowMs
                        TB_HasClicked = true
                    end
                end
            end
        end
    end

    if Settings.AutoClickEnabled and KeybindActive[3] and IsPlayerAlive() then
        local now = os.clock()
        local interval = 1 / Settings.AutoClickCPS
        if now - AC_LastClickTime >= interval then
            mouse1click()
            AC_LastClickTime = now
        end
    end

    if Settings.ManualClashEnabled and KeybindActive[4] and IsPlayerAlive() then
        local ball = GetBall()
        if ball and IsBallTargetingMe(ball) then
            for i = 1, Settings.ManualClashClicksPerBurst do
                mouse1click()
            end
        end
    end

    if Settings.AbilityESP then
        pcall(function()
            local cam = Workspace.CurrentCamera
            if not cam then return end
            local aliveFolder = Workspace:FindFirstChild("Alive")
            if not aliveFolder then return end

            local er, eg, eb = GetPickerColorRGB(1)
            local dr, dg, db = GetPickerColorRGB(2)
            local fontSize = Settings.ESPFontSize

            local aliveNames = {}
            for _, char in pairs(aliveFolder:GetChildren()) do
                aliveNames[char.Name] = true
            end
            for cachedName in pairs(_ESPAbilityCache) do
                if not aliveNames[cachedName] then
                    _ESPAbilityCache[cachedName] = nil
                end
            end

            local localChar = LocalPlayer.Character
            local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")

            for _, char in pairs(aliveFolder:GetChildren()) do
                if char.Name ~= LocalPlayer.Name then
                    local head = char:FindFirstChild("Head")
                    local hrp  = char:FindFirstChild("HumanoidRootPart")
                    local targetPart = head or hrp
                    if targetPart then
                        local abovePos = targetPart.Position + Vector3.new(0, 2.5, 0)
                        local pos, onScreen = cam:WorldToScreenPoint(abovePos)
                        if onScreen then
                            local abilityText = nil
                            local playerObj = Players:FindFirstChild(char.Name)
                            if playerObj then
                                local a = playerObj:GetAttribute("EquippedAbility")
                                if a and tostring(a) ~= "" then abilityText = tostring(a) end
                            end
                            if not abilityText then
                                local a = char:GetAttribute("EquippedAbility")
                                if a and tostring(a) ~= "" then abilityText = tostring(a) end
                            end
                            if not abilityText and hrp then
                                local a = hrp:GetAttribute("EquippedAbility")
                                if a and tostring(a) ~= "" then abilityText = tostring(a) end
                            end
                            if abilityText and abilityText ~= "" then
                                _ESPAbilityCache[char.Name] = abilityText
                            else
                                abilityText = _ESPAbilityCache[char.Name]
                            end

                            if abilityText and abilityText ~= "" then
                                local ts = GetTextSize(abilityText, fontSize)
                                DrawTextOutlined(abilityText, pos.X - ts.X / 2, pos.Y, er, eg, eb, 255, fontSize)
                            end

                            if Settings.ESPShowDistance and localHRP and hrp then
                                local dx = hrp.Position.X - localHRP.Position.X
                                local dy = hrp.Position.Y - localHRP.Position.Y
                                local dz = hrp.Position.Z - localHRP.Position.Z
                                local dist = math.floor(math.sqrt(dx*dx + dy*dy + dz*dz))
                                local distTxt = dist .. " studs"
                                local dts = GetTextSize(distTxt, 12)
                                DrawTextOutlined(distTxt, pos.X - dts.X / 2, pos.Y + fontSize + 2, dr, dg, db, 200, 12)
                            end
                        end
                    end
                end
            end
        end)
    end

    if Settings.BallStatsEnabled then
        local cam = Workspace.CurrentCamera
        if cam then
            local ball = GetBall()
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            if ball and hrp then
                local screenPos, onScreen = cam:WorldToScreenPoint(ball.Position)
                if onScreen then
                    local dx = ball.Position.X - hrp.Position.X
                    local dy = ball.Position.Y - hrp.Position.Y
                    local dz = ball.Position.Z - hrp.Position.Z
                    local distance = math.floor(math.sqrt(dx*dx + dy*dy + dz*dz))
                    local vel = ball.Velocity
                    local speed = math.floor(math.sqrt(vel.X*vel.X + vel.Y*vel.Y + vel.Z*vel.Z))
                    local displayText = distance .. " studs | " .. speed .. " speed"
                    if Settings.ManualClashEnabled and KeybindActive[4] then
                        displayText = "CLASH | " .. distance .. " studs"
                    elseif Settings.AutoCurveEnabled and KeybindActive[5] then
                        displayText = "CURVE | " .. distance .. " studs"
                    end
                    local sr, sg, sb = 0, 255, 255
                    if distance <= 30 then sr, sg, sb = 255, 50, 50
                    elseif distance <= 45 then sr, sg, sb = 255, 165, 0
                    elseif distance <= 70 then sr, sg, sb = 255, 255, 0 end
                    local statTs = GetTextSize(displayText, 14)
                    DrawTextOutlined(displayText, screenPos.X - statTs.X / 2, screenPos.Y - 60, sr, sg, sb, 255, 14)
                end
            end
        end
    end

    if Settings.BallTracerEnabled then
        local cam = Workspace.CurrentCamera
        if cam then
            local ball = GetBall()
            if ball then
                local screenBall, onScreen = cam:WorldToScreenPoint(ball.Position)
                if onScreen then
                    local vp = cam.ViewportSize
                    local tr, tg, tb = GetPickerColorRGB(5)
                    local tAlpha = Settings.BallTracerOpacity / 100
                    DI.Line(
                        V2(vp.X * 0.5, vp.Y),
                        V2(screenBall.X, screenBall.Y),
                        C3(tr, tg, tb), tAlpha, 1, Settings.BallTracerThickness
                    )
                end
            end
        end
    end

    if Settings.PlayerBoxesEnabled then
        local cam = Workspace.CurrentCamera
        if cam then
            local aliveFolder = Workspace:FindFirstChild("Alive")
            if aliveFolder then
                local br, bg_, bb = GetPickerColorRGB(6)
                local fr, fg, fb = GetPickerColorRGB(7)
                for _, char in pairs(aliveFolder:GetChildren()) do
                    if char.Name ~= LocalPlayer.Name then
                        local hrp  = char:FindFirstChild("HumanoidRootPart")
                        local head = char:FindFirstChild("Head")
                        if hrp and head then
                            local topWorld    = head.Position + Vector3.new(0, 0.8, 0)
                            local bottomWorld = hrp.Position  - Vector3.new(0, 3.0, 0)
                            local topSc,  topVis    = cam:WorldToScreenPoint(topWorld)
                            local botSc,  botVis    = cam:WorldToScreenPoint(bottomWorld)
                            if topVis and botVis then
                                local height = math.abs(botSc.Y - topSc.Y)
                                local width  = height * 0.5
                                local left   = topSc.X - width * 0.5
                                local top    = topSc.Y
                                local boxAlphaInt = math.floor(Settings.PlayerBoxOpacity / 100 * 255)
                                local fillAlphaInt = math.floor(Settings.PlayerBoxFillOpacity / 100 * 255)
                                if Settings.PlayerBoxFilled then
                                    DrawRectFilled(left, top, width, height, fr, fg, fb, fillAlphaInt)
                                end
                                DrawRect(left, top, width, height, br, bg_, bb, boxAlphaInt, Settings.PlayerBoxThickness)
                            end
                        end
                    end
                end
            end
        end
    end

    if Settings.ParryCircleEnabled then
        pcall(function()
            local cam = Workspace.CurrentCamera
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            if not cam or not hrp then return end

            local ball = GetBall()
            local ballSpeed = 0
            local ballInRange = false
            if ball then
                local ok, vel = pcall(function() return ball.Velocity end)
                if ok and vel then
                    ballSpeed = math.sqrt(vel.X*vel.X + vel.Y*vel.Y + vel.Z*vel.Z)
                end
                if ballSpeed > 10 then
                    local dx = ball.Position.X - hrp.Position.X
                    local dy = ball.Position.Y - hrp.Position.Y
                    local dz = ball.Position.Z - hrp.Position.Z
                    local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
                    ballInRange = dist <= Settings.ParryDistance
                end
            end

            local radiusScale = Settings.ParryCircleRadiusScale / 100
            local idleRadius = 40 * radiusScale + 10
            local trueRadius = ballSpeed > 10 and ((ballSpeed * 0.42 + 10) * radiusScale) or nil
            if not _parryCircleRadius then _parryCircleRadius = idleRadius end
            local targetRadius = trueRadius or idleRadius
            local lerpSpeed = trueRadius and 0.25 or 0.08
            _parryCircleRadius = _parryCircleRadius + (targetRadius - _parryCircleRadius) * lerpSpeed
            local radius = math.max(3, math.min(_parryCircleRadius, 500))

            local cr, cg, cb
            if ballInRange then
                cr, cg, cb = GetPickerColorRGB(4)
            else
                cr, cg, cb = GetPickerColorRGB(3)
            end
            local cAlpha = math.floor(Settings.ParryCircleOpacity / 100 * 255)
            local th = Settings.ParryCircleThickness
            local groundY = hrp.Position.Y - 3
            local STEPS = 48
            local prevX, prevY = nil, nil
            local firstX, firstY = nil, nil
            local prevVis = false
            for i = 0, STEPS do
                local angle = (i / STEPS) * math.pi * 2
                local wx = hrp.Position.X + math.cos(angle) * radius
                local wz = hrp.Position.Z + math.sin(angle) * radius
                local sp, vis = cam:WorldToScreenPoint(Vector3.new(wx, groundY, wz))
                if vis then
                    if prevVis and prevX then
                        DrawLine(prevX, prevY, sp.X, sp.Y, cr, cg, cb, cAlpha, th)
                    end
                    if not firstX then firstX, firstY = sp.X, sp.Y end
                    prevX, prevY = sp.X, sp.Y
                    prevVis = true
                else
                    prevVis = false
                end
            end
            if firstX and prevX and prevVis then
                DrawLine(prevX, prevY, firstX, firstY, cr, cg, cb, cAlpha, th)
            end
        end)
    end

    if Settings.FPSEnabled then
        local now = os.clock()
        local dt = now - _fpsLastFrame
        _fpsLastFrame = now
        table.insert(_fpsSamples, dt)
        if #_fpsSamples > 30 then table.remove(_fpsSamples, 1) end
        local avg = 0
        for _, s in ipairs(_fpsSamples) do avg = avg + s end
        avg = avg / math.max(#_fpsSamples, 1)
        local fps = math.floor(1 / avg + 0.5)
        local fr, fg, fb = GetPickerColorRGB(8)
        if fps < 30 then fr, fg, fb = 255, 60, 60
        elseif fps < 60 then fr, fg, fb = 255, 165, 0 end
        local label = fps .. " FPS"
        local cam = Workspace.CurrentCamera
        local vp = cam and cam.ViewportSize or Vector2.new(1920, 1080)
        local ts = Settings.FPSTextSize
        local labelSz = GetTextSize(label, ts)
        local padX, padY = 6, 4
        local panelW = labelSz.X + padX * 2
        local panelH = labelSz.Y + padY * 2
        local panelX = vp.X - panelW - 8
        local panelY = 8
        DrawRectFilled(panelX, panelY, panelW, panelH, 18, 18, 28, 220)
        DrawRect(panelX, panelY, panelW, panelH, 60, 60, 60, 200)
        DrawTextOutlined(label, panelX + padX, panelY + padY, fr, fg, fb, 255, ts)
    end

    -- Render notifications AFTER all other visuals, so they sit on top
    RenderNotifications()

    RenderKeybindList(mx, my, lDown)

    RenderMenu(mx, my, lDown, Menu.PrevLMB, rDown, Menu.PrevRMB)

    if not lDown then Menu.ActiveSlider = -1 end

    Menu.PrevLMB = lDown
    Menu.PrevRMB = rDown
end

local CONFIG_FOLDER = "INTERCEPTION"
local CONFIG_PATH = CONFIG_FOLDER .. "/config.json"

local function SaveConfig()
    local data = {
        settings = Settings,
        keybinds = Keybinds,
        keybindModes = KeybindMode,
        keybindActive = KeybindActive,
        menuKey = Menu.MenuKey,
        showKeybindList = Menu.ShowKeybindList,
        pickerColors = PickerColors,
    }
    local ok, json = pcall(crypt.json.encode, data)
    if ok then
        writefile(CONFIG_PATH, json)
    end
end

local function LoadConfig()
    if not isfile(CONFIG_PATH) then return end
    local ok, content = pcall(readfile, CONFIG_PATH)
    if not ok then return end
    local ok2, data = pcall(crypt.json.decode, content)
    if not ok2 or type(data) ~= "table" then return end

    if data.settings then
        for k, v in pairs(data.settings) do
            if Settings[k] ~= nil then Settings[k] = v end
        end
    end
    if data.keybinds then
        for i, v in pairs(data.keybinds) do
            local idx = tonumber(i)
            if idx and idx >= 1 and idx <= MAX_KEYBINDS then
                if type(v) == "string" then Keybinds[idx] = v end
            end
        end
    end
    if data.keybindModes then
        for i, v in pairs(data.keybindModes) do
            local idx = tonumber(i)
            if idx and idx >= 1 and idx <= MAX_KEYBINDS then KeybindMode[idx] = v end
        end
    end
    if data.keybindActive then
        for i, v in pairs(data.keybindActive) do
            local idx = tonumber(i)
            if idx and idx >= 1 and idx <= MAX_KEYBINDS then KeybindActive[idx] = v end
        end
    end
    if data.menuKey and type(data.menuKey) == "string" then Menu.MenuKey = data.menuKey end
    if data.pickerColors then
        for k, v in pairs(data.pickerColors) do
            local id = tonumber(k)
            if id and type(v) == "table" and #v == 3 then
                PickerColors[id] = v
            end
        end
    end
end

if not isfolder(CONFIG_FOLDER) then
    makefolder(CONFIG_FOLDER)
end

LoadConfig()

local renderConnection = RunService.Render and RunService.Render:Connect(OnRender)
    or RunService.Heartbeat and RunService.Heartbeat:Connect(OnRender)

task.spawn(function()
    while _running do
        task.wait(30)
        SaveConfig()
    end
end)

return {
    Menu = Menu,
    Settings = Settings,
    Keybinds = Keybinds,
    KeybindActive = KeybindActive,
    KeybindMode = KeybindMode,
    PickerColors = PickerColors,
    SetPickerColor = SetPickerColor,
    GetPickerColor = GetPickerColor,
    GetPickerColorRGB = GetPickerColorRGB,
    HSVtoRGB = HSVtoRGB,
    SaveConfig = SaveConfig,
    LoadConfig = LoadConfig,
    PushNotification = PushNotification,
    DrawRect = DrawRect,
    DrawRectFilled = DrawRectFilled,
    DrawLine = DrawLine,
    DrawCircle = DrawCircle,
    DrawTextShadow = DrawTextShadow,
    GetTextSize = GetTextSize,
    DrawGroupBox = DrawGroupBox,
    DrawCheckboxRow = DrawCheckboxRow,
    DrawSliderRow = DrawSliderRow,
    DrawDropdownRow = DrawDropdownRow,
    DrawDropdownList = DrawDropdownList,
    DrawDropdownFlagList = DrawDropdownFlagList,
    DrawColorPickerButton = DrawColorPickerButton,
    DrawKeybindButton = DrawKeybindButton,
    Destroy = function()
        _running = false
        if renderConnection then renderConnection:Disconnect() end
        SaveConfig()
    end,
}
