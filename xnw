local function GetKeybindExclusion(kbSlot)
    if not kbSlot then return 36 end
    local text
    if Menu.ListeningKB == kbSlot then
        text = "[...]"
    elseif Keybinds[kbSlot] == "" then
        text = "[-]"
    else
        text = "[" .. KeyToDisplay(Keybinds[kbSlot]) .. "]"
    end
    return GetTextSize(text).X + 8
end

local function DrawCheckboxRow(x, y, w, label, val, mx, my, lDown, prevLMB, kbSlot)
    local sz = 12
    local rowH = 20
    local cy = y + (rowH / 2) - (sz / 2)
    local clicked = false

    if Menu.PickerOpenID == 0 and Menu.OpenDropdownID == 0 and Menu.ActiveSlider == -1
       and not Menu.Dragging and Menu.ListeningKB < 0 and Menu.KBModeDropdown < 0 then
        local hitW = w - GetKeybindExclusion(kbSlot)
        local hover = mx >= x and mx <= x + hitW and my >= y and my <= y + rowH
        if hover and lDown and not prevLMB then clicked = true end
    end

    local show = val
    if clicked then show = not show end

    DrawMenuRect(x, cy, sz, sz, 40, 40, 40)
    DrawMenuBorder(x, cy, sz, sz, 70, 70, 70)

    if show then
        DrawLine(x + 2, cy + sz / 2, x + sz / 2 - 1, cy + sz - 3, 220, 220, 220, 255, 1.5)
        DrawLine(x + sz / 2 - 1, cy + sz - 3, x + sz - 2, cy + 2, 220, 220, 220, 255, 1.5)
    end

    DrawTextShadow(label, x + sz + 6, y + 3, 220, 220, 220, 255, 0, 0, 0, 255)
    return clicked, show
end

local function DrawSliderRow(x, y, w, label, val, minVal, maxVal, sid, mx, my, lDown, displayDiv, suffix)
    displayDiv = displayDiv or 1
    suffix = suffix or ""
    local barY = y + 14
    local barH = 6

    if Menu.PickerOpenID == 0 and Menu.OpenDropdownID == 0 and not Menu.Dragging
       and Menu.ListeningKB < 0 and Menu.KBModeDropdown < 0 then
        local hover = mx >= x - 4 and mx <= x + w + 4 and my >= barY - 4 and my <= barY + barH + 4
        if hover and lDown and Menu.ActiveSlider == -1 then
            Menu.ActiveSlider = sid
        end
    end

    if Menu.ActiveSlider == sid then
        local f = (mx - x) / w
        f = math.max(0, math.min(1, f))
        val = minVal + math.floor(f * (maxVal - minVal) + 0.5)
    end

    local frac = (val - minVal) / (maxVal - minVal)
    local knobX = x + frac * w

    DrawTextShadow(label, x, y, 220, 220, 220, 255, 0, 0, 0, 255)

    local vt
    if displayDiv > 1 then
        local fval = val / displayDiv
        vt = string.format("%.2f", fval)
    else
        vt = tostring(val)
    end
    if #suffix > 0 then vt = vt .. suffix end

    local vs = GetTextSize(vt)
    DrawTextShadow(vt, x + w - vs.X, y, 180, 180, 180, 255, 0, 0, 0, 255)

    DrawMenuRect(x, barY, w, barH, 40, 40, 40)
    DrawMenuBorder(x, barY, w, barH, 70, 70, 70)
    if frac > 0 then
        DrawMenuRect(x, barY, frac * w, barH, 180, 180, 180)
    end
    DrawMenuRect(knobX - 2, barY - 2, 4, barH + 4, 220, 220, 220)

    return val
end

local function DrawDropdownRow(x, y, w, label, display, ddID, mx, my, lDown, prevLMB)
    local boxH = 20
    DrawTextShadow(label, x, y, 220, 220, 220, 255, 0, 0, 0, 255)

    local boxY = y + 14
    DrawMenuRect(x, boxY, w, boxH, 40, 40, 40)
    DrawMenuBorder(x, boxY, w, boxH, 70, 70, 70)

    local maxTextW = w - 20
    local drawText = display
    local dtSz = GetTextSize(drawText)
    if dtSz.X > maxTextW then
        while #drawText > 0 and dtSz.X > maxTextW do
            drawText = drawText:sub(1, #drawText - 1)
            dtSz = GetTextSize(drawText .. "...")
        end
        drawText = drawText .. "..."
    end

    DrawTextShadow(drawText, x + 4, boxY + 3, 180, 180, 180, 255, 0, 0, 0, 255)

    local arrowX = x + w - 12
    local arrowY = boxY + boxH / 2
    DrawLine(arrowX - 3, arrowY - 2, arrowX, arrowY + 2, 180, 180, 180, 255)
    DrawLine(arrowX, arrowY + 2, arrowX + 3, arrowY - 2, 180, 180, 180, 255)

    if Menu.PickerOpenID == 0 and Menu.ActiveSlider == -1 and not Menu.Dragging and Menu.KBModeDropdown < 0 then
        if Menu.OpenDropdownID == 0 or Menu.OpenDropdownID == ddID then
            local hover = mx >= x and mx <= x + w and my >= boxY and my <= boxY + boxH
            if hover and lDown and not prevLMB then
                if Menu.OpenDropdownID == ddID then
                    Menu.OpenDropdownID = 0
                else
                    Menu.OpenDropdownID = ddID
                    Menu.DDJustOpened = true
                    Menu.DDPosX = x
                    Menu.DDPosY = boxY + boxH
                    Menu.DDPosW = w
                end
            end
        end
    end
end

