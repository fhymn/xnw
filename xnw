local function V2(x, y) return Vector2.new(x, y) end
local function C3(r, g, b) return Color3.fromRGB(r, g, b) end

local function DrawRect(x, y, w, h, r, g, b, a, thickness)
    thickness = thickness or 1
    a = a or 255
    DI.Rectangle(V2(x, y), V2(w, h), C3(r, g, b), a / 255, thickness)
end

local function DrawRectFilled(x, y, w, h, r, g, b, a)
    a = a or 255
    DI.FilledRectangle(V2(x, y), V2(w, h), C3(r, g, b), a / 255)
end

local function DrawLine(x1, y1, x2, y2, r, g, b, a, thickness)
    thickness = thickness or 1
    a = a or 255
    DI.Line(V2(x1, y1), V2(x2, y2), C3(r, g, b), a / 255, 1, thickness)
end

local function DrawCircle(cx, cy, radius, r, g, b, a, thickness, filled)
    a = a or 255
    thickness = thickness or 1
    if filled then
        DI.FilledCircle(V2(cx, cy), radius, C3(r, g, b), a / 255)
    else
        DI.Circle(V2(cx, cy), radius, C3(r, g, b), a / 255, thickness)
    end
end

local function DrawTextOutlined(text, x, y, r, g, b, a, size, font, center)
    a = a or 255
    size = size or FONT_SIZE
    font = font or FONT_DEFAULT
    center = center or false
    DI.OutlinedText(V2(x, y), size, C3(r, g, b), a / 255, text, center, font)
end

local function DrawTextShadow(text, x, y, r, g, b, a, sr, sg, sb, sa, size, font)
    sr = sr or 0; sg = sg or 0; sb = sb or 0; sa = sa or 255
    size = size or FONT_SIZE
    font = font or FONT_DEFAULT
    DI.Text(V2(x + 1, y + 1), size, C3(sr, sg, sb), sa / 255, text, false, font)
    DI.Text(V2(x, y), size, C3(r, g, b), a / 255, text, false, font)
end

local function GetTextSize(text, size, font)
    size = size or FONT_SIZE
    font = font or FONT_DEFAULT
    return DI.GetTextBounds(font, size, text)
end

local function HSVtoRGB(h, s, v)
    local c = v * s
    local x = c * (1 - math.abs((h / 60) % 2 - 1))
    local m = v - c
    local r1, g1, b1 = 0, 0, 0
    if h < 60 then      r1, g1, b1 = c, x, 0
    elseif h < 120 then r1, g1, b1 = x, c, 0
    elseif h < 180 then r1, g1, b1 = 0, c, x
    elseif h < 240 then r1, g1, b1 = 0, x, c
    elseif h < 300 then r1, g1, b1 = x, 0, c
    else                r1, g1, b1 = c, 0, x
    end
    return math.floor((r1 + m) * 255), math.floor((g1 + m) * 255), math.floor((b1 + m) * 255)
end

