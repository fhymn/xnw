        if not SKIP_BIND[k] then
            return k
        end
    end
    return nil
end

-- ============================================
-- NOTIFICATION SYSTEM
-- ============================================
local Notifications = {}
local NOTIF_MAX        = 5
local NOTIF_DURATION   = 3.5   -- seconds visible (fully opaque)
local NOTIF_FADE_IN    = 0.15  -- seconds to fade in
local NOTIF_FADE_OUT   = 0.30  -- seconds to fade out
local NOTIF_W          = 210
local NOTIF_PAD_X      = 10
local NOTIF_PAD_Y      = 6
local NOTIF_TITLE_H    = 14    -- font size for title
local NOTIF_BODY_H     = 12    -- font size for body
local NOTIF_GAP        = 5     -- gap between notifications
local NOTIF_ANCHOR_X   = 14   -- distance from right edge
local NOTIF_ANCHOR_Y   = 14   -- distance from bottom edge
local NOTIF_ACCENT_W   = 3    -- left accent bar width

-- kind -> {R, G, B} accent color
local NOTIF_KIND_COLORS = {
    on      = {80,  220, 120},   -- green
    off     = {255, 80,  80},    -- red
    info    = {80,  160, 255},   -- blue
    warn    = {255, 180, 40},    -- orange
}

local function PushNotification(title, body, kind)
    kind = kind or "info"
    local now = os.clock()
    -- Evict oldest if at cap
    if #Notifications >= NOTIF_MAX then
        table.remove(Notifications, 1)
    end
    table.insert(Notifications, {
        title   = title or "",
        body    = body or "",
        kind    = kind,
        spawnAt = now,
        total   = NOTIF_FADE_IN + NOTIF_DURATION + NOTIF_FADE_OUT,
    })
end

local function RenderNotifications()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local now = os.clock()

    -- Remove expired
    for i = #Notifications, 1, -1 do
        local n = Notifications[i]
        if now - n.spawnAt >= n.total then
            table.remove(Notifications, i)
        end
    end

    -- Layout bottom-up (newest at bottom)
    local curBottomY = vp.Y - NOTIF_ANCHOR_Y

    for i = #Notifications, 1, -1 do
        local n = Notifications[i]
        local elapsed = now - n.spawnAt

        -- Compute alpha
        local alpha = 1
        if elapsed < NOTIF_FADE_IN then
            alpha = elapsed / NOTIF_FADE_IN
        elseif elapsed > NOTIF_FADE_IN + NOTIF_DURATION then
            local fadeElapsed = elapsed - NOTIF_FADE_IN - NOTIF_DURATION
            alpha = 1 - (fadeElapsed / NOTIF_FADE_OUT)
        end
        alpha = math.max(0, math.min(1, alpha))

        local hasBody = n.body and n.body ~= ""

        -- Calculate panel height
        local panelH = NOTIF_PAD_Y * 2 + NOTIF_TITLE_H
        if hasBody then
            panelH = panelH + 3 + NOTIF_BODY_H
        end

        local panelX = vp.X - NOTIF_ANCHOR_X - NOTIF_W
        local panelY = curBottomY - panelH

        local a = math.floor(alpha * 255)
        local aDark = math.floor(alpha * 210)
        local aDim  = math.floor(alpha * 140)
        local aLine = math.floor(alpha * 30)

        -- Background layers (same style as menu windows)
        DrawRectFilled(panelX,     panelY,     NOTIF_W,     panelH,     0,  0,  0,  aDark)
        DrawRectFilled(panelX + 1, panelY + 1, NOTIF_W - 2, panelH - 2, 50, 50, 50, math.floor(alpha * 60))
        DrawRectFilled(panelX + 2, panelY + 2, NOTIF_W - 4, panelH - 4, 25, 25, 25, aDark)

        -- Left accent bar
        local col = NOTIF_KIND_COLORS[n.kind] or NOTIF_KIND_COLORS.info
        DrawRectFilled(panelX + 2, panelY + 2, NOTIF_ACCENT_W, panelH - 4, col[1], col[2], col[3], a)

        -- Title
        local textX = panelX + NOTIF_PAD_X + NOTIF_ACCENT_W
        local titleY = panelY + NOTIF_PAD_Y
        -- shadow
        DI.Text(V2(textX + 1, titleY + 1), NOTIF_TITLE_H, C3(0, 0, 0), (a * 0.8) / 255, n.title, false, FONT_DEFAULT)
        DI.Text(V2(textX,     titleY),     NOTIF_TITLE_H, C3(220, 220, 220), a / 255, n.title, false, FONT_DEFAULT)

        -- Body (dimmer, smaller)
        if hasBody then
            local bodyY = titleY + NOTIF_TITLE_H + 3
            -- separator line
            DrawRectFilled(panelX + NOTIF_PAD_X + NOTIF_ACCENT_W, bodyY - 1, NOTIF_W - NOTIF_PAD_X * 2 - NOTIF_ACCENT_W, 1, 255, 255, 255, aLine)
            DI.Text(V2(textX + 1, bodyY + 1), NOTIF_BODY_H, C3(0, 0, 0), (aDim * 0.8) / 255, n.body, false, FONT_DEFAULT)
            DI.Text(V2(textX,     bodyY),     NOTIF_BODY_H, C3(col[1], col[2], col[3]), aDim / 255, n.body, false, FONT_DEFAULT)
        end

        curBottomY = panelY - NOTIF_GAP
    end
end

