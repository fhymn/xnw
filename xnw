-- ============================================
local AutoCurveState = {
    IsFlicking = false,
    WasTargeted = false,
    QueuedOffset = nil,
}

local CurveDeck = {}
local CurveDeckIndex = 0

local function GetCurveOffsets()
    local x = Config.AutoCurveFlickAngle * 36
    if Config.AutoCurveMode == "strict" then
        return { {x, 0}, {-x, 0} }
    else
        return { {x, 0}, {-x, 0}, {x*2, 0}, {-x*2, 0} }
    end
end

local function ShuffleDeck(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
end

local function RebuildCurveDeck()
    local offsets = GetCurveOffsets()
    CurveDeck = {}
    for i = 1, #offsets do table.insert(CurveDeck, offsets[i]) end
    ShuffleDeck(CurveDeck)
    CurveDeckIndex = 1
end

local function DealNextCurveOffset()
    if CurveDeckIndex > #CurveDeck then
        RebuildCurveDeck()
    end
    AutoCurveState.QueuedOffset = CurveDeck[CurveDeckIndex]
    CurveDeckIndex = CurveDeckIndex + 1
end

RebuildCurveDeck()
DealNextCurveOffset()

local function DoAutoCurveFlick()
    if not Config.AutoCurveEnabled then return end
    if AutoCurveState.IsFlicking then return end
    if not AutoCurveState.QueuedOffset then return end
    local ox = AutoCurveState.QueuedOffset[1] + math.random(-20, 20)
    local oy = AutoCurveState.QueuedOffset[2]
    AutoCurveState.IsFlicking = true
    task.spawn(function()
        mousemoverel(ox, oy)
        task.wait(0.001)
        mouse1click()
        mousemoverel(-ox, -oy)
        AutoCurveState.IsFlicking = false
    end)
end

